---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

interface Props {
  showForm?: boolean;
  sectionId?: string;
  variant?: "full" | "form-only" | "compact";
}

const { showForm = true, sectionId = "Llamar_cita", variant = "full" } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const phone = "+34 629 43 41 82";
---

<section
  class={variant === "form-only" ? "py-[50px] max-w-[1200px] mx-auto px-4 text-center" : "max-w-[1200px] mx-auto py-[50px] px-4"}
  id={sectionId}
>
  {variant === "form-only" ? (
    <>
      <p class="text-brand-text mb-4 text-lg">{t("contact.estamosServicio")}</p>
      <h3 class="text-[33px] font-heading font-light text-brand-primary mb-[40px] max-w-2xl mx-auto">
        {t("contact.formTitle")}
      </h3>
      <div class="max-w-[700px] mx-auto text-left">
        <form class="space-y-6 contact-form" method="post" action="#">
          <div>
            <label for="nombre" class="block text-brand-text font-bold mb-2">
              {t("contact.nameLabel")} <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              required
              class="w-full border border-gray-300 rounded px-4 py-3 focus:outline-none focus:border-brand-primary"
            />
          </div>
          <div>
            <label for="localidad" class="block text-brand-text font-bold mb-2">
              {t("contact.locationLabel")}
            </label>
            <input
              type="text"
              id="localidad"
              name="localidad"
              class="w-full border border-gray-300 rounded px-4 py-3 focus:outline-none focus:border-brand-primary"
            />
            <p class="text-gray-500 text-sm mt-1">{t("contact.locationHint")}</p>
          </div>
          <div>
            <label for="telefono" class="block text-brand-text font-bold mb-2">
              {t("contact.phoneLabel")}
            </label>
            <input
              type="tel"
              id="telefono"
              name="telefono"
              class="w-full border border-gray-300 rounded px-4 py-3 focus:outline-none focus:border-brand-primary"
            />
          </div>
          <div class="text-center pt-4">
            <button
              type="submit"
              class="bg-[#066aab] text-white font-heading font-bold uppercase text-lg px-8 py-3 rounded-[3px] hover:bg-brand-primary transition-colors"
            >
              {t("contact.submit")}
            </button>
          </div>
        </form>
      </div>
    </>
  ) : variant === "compact" ? (
    <>
      <h2 class="font-heading font-bold text-[30px] text-brand-primary uppercase tracking-[0.9px] mb-8 text-center pt-10">
        {t("contact.pedirCita")}
      </h2>
      <div
        class="max-w-[1200px] mx-auto px-4 py-16 text-center"
      style="background-image: url('/images/backgrounds/background-2.png'); background-position: bottom center; background-repeat: no-repeat;"
    >
      <div class="max-w-[800px] mx-auto flex flex-col items-center">
        <img
          loading="lazy"
          width="392"
          height="206"
          src="/images/contact/llamar.jpg"
          class="rounded-lg shadow-md mb-6"
          alt={t("contact.llamando")}
        />
        <p class="font-body text-brand-text text-[33px] font-light leading-[1.3] mb-4">
          {t("contact.llamando")} <strong>{phone}</strong>
        </p>
        <p class="font-body text-brand-text text-[17px] leading-[37px] mb-4">
          {t("contact.scheduleText")}
        </p>
        <p class="font-body text-brand-text text-[17px] leading-[37px] mb-8">
          {t("contact.estamosServicio")}
        </p>
      </div>
    </div>
    </>
  ) : (
    <>
      <h2 class="text-brand-primary font-heading font-bold text-[30px] uppercase text-center tracking-[0.9px] mb-10">
        {t("contact.pedirCita")}
      </h2>
      <div class="bg-[url('/images/backgrounds/background-2.png')] bg-bottom bg-no-repeat flex flex-col md:flex-row shadow-sm border border-gray-100 p-10">
        <div class="w-full md:w-1/2 flex flex-col items-center justify-center text-brand-text font-body p-4 text-[17px] leading-[37px] text-center">
          <img
            src="/images/contact/llamar.jpg"
            class="mb-6 w-[200px]"
            alt={t("contact.llamando")}
          />
          <p class="text-[33px] font-heading font-light tracking-[0.9px] text-[#000]">
            {t("contact.llamando")} <strong>{phone}</strong>
          </p>
          <p class="mt-4">{t("contact.scheduleText")}</p>
          <p class="mt-4 font-bold">{t("contact.estamosServicio")}</p>
        </div>
        {showForm && (
          <div class="w-full md:w-1/2 mt-10 md:mt-0 p-4">
            <h3 class="text-brand-text font-heading font-medium text-[25px] text-center mb-6">
              {t("contact.formTitle")}
            </h3>
            <form class="flex flex-col gap-4 font-body contact-form" method="post" action="#">
              <div>
                <label class="block text-brand-text font-semibold mb-2" for="name">
                  {t("contact.nameLabel")} *
                </label>
                <input type="text" id="name" name="name" required class="w-full border border-gray-300 rounded p-3" />
              </div>
              <div>
                <label class="block text-brand-text font-semibold mb-2" for="location">
                  {t("contact.locationLabel")}
                </label>
                <p class="text-[13px] text-gray-500 mb-1">{t("contact.locationHint")}</p>
                <input type="text" id="location" name="location" class="w-full border border-gray-300 rounded p-3" />
              </div>
              <div>
                <label class="block text-brand-text font-semibold mb-2" for="phone">
                  {t("contact.phoneLabel")}
                </label>
                <input type="tel" id="phone" name="phone" class="w-full border border-gray-300 rounded p-3" />
              </div>
              <div class="text-center pt-2">
                <button
                  type="submit"
                  class="bg-brand-primary text-white font-heading font-bold uppercase px-8 py-3 rounded hover:bg-brand-accent transition-colors"
                >
                  {t("contact.submit")}
                </button>
              </div>
            </form>
          </div>
        )}
      </div>
    </>
  )}
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const isEn = () => document.documentElement.lang === "en";
    document.querySelectorAll(".contact-form").forEach((form) => {
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        const formEl = e.target as HTMLFormElement;
        const btn = formEl.querySelector('button[type="submit"]') as HTMLButtonElement;
        if (btn) {
          btn.disabled = true;
          btn.textContent = isEn() ? "Sending..." : "Enviando...";
        }
        const endpoint = (import.meta as any).env?.PUBLIC_FORM_ENDPOINT;
        if (endpoint) {
          const data = new FormData(formEl);
          fetch(endpoint, { method: "POST", body: data })
            .then(() => {
              if (btn) btn.textContent = isEn() ? "Sent!" : "¡Enviado!";
            })
            .catch(() => {
              if (btn) {
                btn.disabled = false;
                btn.textContent = isEn() ? "Submit" : "Enviar";
              }
            });
        } else {
          if (btn) {
            btn.textContent = isEn() ? "Call +34 629 43 41 82" : "Llame al +34 629 43 41 82";
            btn.disabled = false;
          }
        }
      });
    });
  });
</script>
