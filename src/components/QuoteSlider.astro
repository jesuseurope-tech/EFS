---
const quotes = [
  {
    text: "Antes de curar a alguien, pregúntale si está dispuesto a renunciar a aquello que le enfermó.",
    author: "Hipócrates",
  },
  {
    text: "La salud depende de estar en armonía con nuestras almas.",
    author: "Edward Bach",
  },
  {
    text: "La medicina debe integrar cuerpo, alma y espíritu para que el tratamiento sea verdadero y duradero.",
    author: "Rudolf Steiner",
  },
  {
    text: "El verdadero médico no solo receta, sino que escucha, comprende y guía hacia el equilibrio.",
    author: "Anónimo",
  },
  {
    text: "La homeopatía no trata enfermedades, sino personas que están enfermas.",
    author: "André Saine",
  },
  {
    text: "El cuerpo susurra antes de gritar; el médico atento escucha el silencio de la enfermedad antes de que se manifieste.",
    author: "Frase propuesta",
  },
  {
    text: "La tecnología sana, la química actúa, pero el alma se cura en presencia del amor y la escucha.",
    author: "Frase propuesta",
  },
  {
    text: "La única y gran misión del médico es restablecer la salud del enfermo, es aquello que se llama curar.",
    author: "Samuel Hahnemann",
  },
  {
    text: "El buen médico trata la enfermedad; el gran médico trata al paciente que tiene la enfermedad.",
    author: "William Osler",
  },
];
---

<div class="w-full max-w-[1000px] mx-auto px-4 py-16">
  <div
    class="relative bg-white rounded-3xl shadow-sm border border-gray-100 p-8 md:p-12 overflow-hidden h-[300px] md:h-[250px] flex items-center justify-center"
  >
    <!-- Decorative Quote Icon Background -->
    <div
      class="absolute top-4 left-4 md:top-8 md:left-8 text-slate-50 opacity-50 pointer-events-none"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="120"
        height="120"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path
          d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"
        ></path>
      </svg>
    </div>

    <div id="testimonial-container" class="relative z-10 w-full text-center">
      {
        quotes.map((quote, index) => (
          <div
            class="testimonial-slide hidden opacity-0 transition-opacity duration-1000 ease-in-out absolute inset-0 flex-col items-center justify-center"
            data-index={index}
          >
            <p class="text-xl md:text-2xl font-serif italic text-brand-text mb-6 pb-6 border-b border-gray-100 max-w-3xl mx-auto leading-relaxed">
              "{quote.text}"
            </p>
            <p class="font-heading font-bold text-brand-secondary tracking-wider uppercase text-sm">
              — {quote.author}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  function initTestimonials() {
    const slides = document.querySelectorAll(".testimonial-slide");
    if (!slides.length) return;

    let currentSlide = 0;

    // Show first slide immediately
    slides[0].classList.remove("hidden");
    // Allow a tiny delay for browser to process the display block before fading to trigger transition
    setTimeout(() => {
      slides[0].classList.remove("opacity-0");
      slides[0].classList.add("opacity-100");
    }, 50);

    setInterval(() => {
      // Hide current
      const oldSlide = slides[currentSlide];
      oldSlide.classList.remove("opacity-100");
      oldSlide.classList.add("opacity-0");

      setTimeout(() => {
        oldSlide.classList.add("hidden");
      }, 1000); // Wait for fade out transition

      // Update index
      currentSlide = (currentSlide + 1) % slides.length;

      // Show next
      const newSlide = slides[currentSlide];
      // ensure we don't start showing it visually until old one finishes fade
      setTimeout(() => {
        newSlide.classList.remove("hidden");
        setTimeout(() => {
          newSlide.classList.remove("opacity-0");
          newSlide.classList.add("opacity-100");
        }, 50);
      }, 1000);
    }, 8000); // Change slides every 8 seconds
  }

  // Initialize on load and when navigating via ViewTransitions (if used)
  document.addEventListener("DOMContentLoaded", initTestimonials);
  document.addEventListener("astro:page-load", initTestimonials);
</script>

<style>
  /* Any additional specific styles not covered by tailwind, but mostly handled by tailwind classes */
  .testimonial-slide {
    /* Using absolute positioning and flex allows vertical centering within the relative container */
    display: none;
  }

  .testimonial-slide:not(.hidden) {
    display: flex;
  }
</style>
