---
import Layout from "./Layout.astro";
import Locations from "../components/Locations.astro";
import ContactSection from "../components/ContactSection.astro";

interface Props {
  title: string;
  description?: string;
  lang?: string;
  doctorName: string;
  doctorRole: string;
  doctorImageUrl?: string;
}

const {
  title,
  description,
  lang = "es",
  doctorName,
  doctorRole,
  doctorImageUrl,
} = Astro.props;
---

<Layout title={title} description={description} lang={lang}>
  <!-- Hero Section specific to Doctor Profile -->
  <section
    class="bg-slate-50 pt-32 pb-16 md:pt-40 md:pb-24 overflow-hidden relative"
  >
    <div
      class="absolute inset-0 z-0 opacity-10 bg-[url('/images/pattern-bg.svg')] bg-repeat"
      aria-hidden="true"
    >
    </div>
    <div class="max-w-[1000px] mx-auto px-4 relative z-10">
      <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
        {
          doctorImageUrl && (
            <div class="w-48 h-48 md:w-64 md:h-64 flex-shrink-0 animate-fade-in-up">
              <img
                src={doctorImageUrl}
                alt={doctorName}
                class="w-full h-full object-cover rounded-full shadow-2xl border-4 border-white object-top"
              />
            </div>
          )
        }
        <div
          class="text-center md:text-left animate-fade-in-up"
          style="animation-delay: 100ms;"
        >
          <h1
            class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-brand-primary mb-4"
          >
            {doctorName}
          </h1>
          <p
            class="text-xl md:text-2xl text-brand-secondary font-medium font-body mb-6"
          >
            {doctorRole}
          </p>
          <div class="w-20 h-1 bg-brand-accent rounded-full mx-auto md:mx-0">
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-16 md:py-24">
    <div class="max-w-[800px] mx-auto px-4">
      <article
        class="prose prose-lg md:prose-xl max-w-none text-brand-text font-body leading-relaxed"
      >
        <slot />
      </article>

      <div class="mt-16 flex justify-center">
        <!-- Replaced by ContactSection below -->
      </div>
    </div>
  </section>

  <Locations />
  <ContactSection sectionId={lang === "es" ? "contacto" : "contact"} />
</Layout>
