---
import Layout from "./Layout.astro";
import Locations from "../components/Locations.astro";
import ContactSection from "../components/ContactSection.astro";

interface Props {
  title: string;
  description?: string;
  lang?: string;
  treatmentName: string;
}

const { title, description, lang = "es", treatmentName } = Astro.props;
---

<Layout title={title} description={description} lang={lang}>
  <div
    class="max-w-[1200px] mx-auto px-4 py-12 md:py-20 flex flex-col md:flex-row gap-10"
  >
    <!-- Main Content Area -->
    <article class="w-full md:w-3/4">
      <header class="mb-10">
        <h1
          class="text-4xl md:text-5xl font-heading font-bold text-brand-primary mb-4 leading-tight"
        >
          {treatmentName}
        </h1>
        <div class="w-20 h-1 bg-brand-secondary rounded-full"></div>
      </header>

      <div class="prose prose-lg max-w-none text-brand-text">
        <slot />
      </div>
    </article>

    <!-- Sidebar Area (Optional, for related links or CTA) -->
    <aside class="w-full md:w-1/4 mt-10 md:mt-0">
      <div
        class="bg-gray-50 p-6 rounded-2xl shadow-sm border border-gray-100 sticky top-24"
      >
        <h3
          class="font-heading font-bold text-xl text-brand-primary mb-4 border-b pb-2"
        >
          Consulta Médica
        </h3>
        <p class="text-sm text-gray-600 mb-6 font-body">
          {
            lang === "es"
              ? "Descubre cómo podemos ayudarte con un enfoque integral y personalizado."
              : "Discover how we can help you with a comprehensive and personalized approach."
          }
        </p>
        <a
          href={lang === "es" ? "#contacto" : "#contact"}
          class="block w-full text-center bg-brand-primary text-white font-bold py-3 px-4 rounded-lg hover:bg-brand-secondary transition-colors duration-300 shadow-md hover:shadow-lg"
        >
          {lang === "es" ? "Solicitar Cita" : "Request Appointment"}
        </a>
      </div>
    </aside>
  </div>

  <Locations />
  <ContactSection sectionId={lang === "es" ? "contacto" : "contact"} />
</Layout>
