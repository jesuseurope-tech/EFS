---
import Layout from "../../../layouts/Layout.astro";
import ContactSection from "../../../components/ContactSection.astro";
import { getLangFromUrl } from "../../../i18n/utils";
import MainTreatments from "../../../components/MainTreatments.astro";
import Locations from "../../../components/Locations.astro";

const lang = getLangFromUrl(Astro.url);
---

<Layout title="Complete Detoxification" lang={lang}>
  <!-- Hero Section with Background -->
  <section
    class="bg-[url('/images/backgrounds/frequency-cancel-out.png')] bg-center bg-no-repeat bg-cover w-full py-[150px] md:py-[200px] flex items-center justify-center"
  >
    <div class="max-w-[1200px] w-full mx-auto px-4 text-center bg-white p-8">
      <h1
        class="text-brand-text font-heading font-bold text-[30px] uppercase tracking-[0.9px]"
      >
        Advanced detoxification through bio-frequencies
      </h1>
    </div>
  </section>

  <!-- Intro Block -->
  <section class="max-w-[1200px] mx-auto py-12 px-4 text-center">
    <div
      class="text-brand-text font-body text-[20px] md:text-[30px] leading-[1.6]"
    >
      <p>
        We carry out an advanced medical detoxification process, using
        state-of-the-art bio-frequencies, designed to help you eliminate harmful
        substances and revitalize your body effectively.
      </p>
    </div>
  </section>

  <section class="max-w-[1200px] mx-auto pb-12 px-4 text-center">
    <h2
      class="text-brand-primary font-heading font-bold text-[30px] md:text-[45px] uppercase tracking-[0.9px] mb-8"
    >
      We Identify and Treat Countless Types of Toxins
    </h2>
    <div
      class="text-brand-text text-[17px] leading-[37px] font-body text-left max-w-[1000px] mx-auto space-y-4"
    >
      <p>
        We use advanced bio-frequency technology that has proven its high
        efficacy in other medical treatments that I offer in the clinic. This
        system detects the energetic 'signatures' (frequencies) of specific
        toxins present in your body. Using a specialized device, we apply
        inverse electromagnetic frequencies that neutralize toxic information at
        the cellular level. This helps your body eliminate those harmful
        substances more efficiently and restore its natural function without
        overloads, in a non-invasive way.
      </p>
    </div>
  </section>

  <!-- Toxins Grid -->
  <section class="max-w-[1200px] mx-auto mb-16 px-4 font-body">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
      <div
        class="bg-white p-6 rounded-lg shadow-md border-l-4 border-[#158EC7] transition-transform hover:scale-105 flex flex-col"
      >
        <div class="flex items-center mb-2">
          <span class="text-2xl mr-2 text-[#158EC7]">🌍</span>
          <h3 class="font-bold text-[20px] text-[#172550]">
            Environmental Toxins
          </h3>
        </div>
        <p class="text-[14px] text-[#3B3B3B] leading-relaxed">
          Paints, solvents, asbestos, pesticides, pollens, preservatives, fuels,
          mold, air, water and food pollutants, etc...
        </p>
      </div>

      <div
        class="bg-white p-6 rounded-lg shadow-md border-l-4 border-[#FAB604] transition-transform hover:scale-105 flex flex-col"
      >
        <div class="flex items-center mb-2">
          <span class="text-2xl mr-2 text-[#FAB604]">🏠</span>
          <h3 class="font-bold text-[20px] text-[#172550]">Domestic Toxins</h3>
        </div>
        <p class="text-[14px] text-[#3B3B3B] leading-relaxed">
          Compounds in cosmetics, ointments, emulsions, natural fabrics, textile
          dyes and detergents etc...
        </p>
      </div>

      <div
        class="bg-white p-6 rounded-lg shadow-md border-l-4 border-[#172550] transition-transform hover:scale-105 flex flex-col"
      >
        <div class="flex items-center mb-2">
          <span class="text-2xl mr-2 text-[#172550]">💊</span>
          <h3 class="font-bold text-[20px] text-[#172550]">Medical Toxins</h3>
        </div>
        <p class="text-[14px] text-[#3B3B3B] leading-relaxed">
          Drug residues, malaria prophylaxis and poisons. Sequelae of childhood
          diseases etc...
        </p>
      </div>

      <div
        class="bg-white p-6 rounded-lg shadow-md border-l-4 border-[#158EC7] transition-transform hover:scale-105 flex flex-col"
      >
        <div class="flex items-center mb-2">
          <span class="text-2xl mr-2 text-[#158EC7]">🔗</span>
          <h3 class="font-bold text-[20px] text-[#172550]">Heavy Metals</h3>
        </div>
        <p class="text-[14px] text-[#3B3B3B] leading-relaxed">
          Lead, mercury, cadmium, dental amalgams, arsenic, beryllium,
          palladium, nickel/chromium etc...
        </p>
      </div>

      <div
        class="bg-white p-6 rounded-lg shadow-md border-l-4 border-[#FAB604] transition-transform hover:scale-105 flex flex-col"
      >
        <div class="flex items-center mb-2">
          <span class="text-2xl mr-2 text-[#FAB604]">🦠</span>
          <h3 class="font-bold text-[20px] text-[#172550]">
            Biological Agents
          </h3>
        </div>
        <p class="text-[14px] text-[#3B3B3B] leading-relaxed">
          Bacteria, viruses, parasites, mycosis (fungi), epithelia (animals),
          wood and vegetable fibers, photoallergens etc...
        </p>
      </div>

      <div
        class="bg-white p-6 rounded-lg shadow-md border-l-4 border-[#172550] transition-transform hover:scale-105 flex flex-col"
      >
        <div class="flex items-center mb-2">
          <span class="text-2xl mr-2 text-[#172550]">📡</span>
          <h3 class="font-bold text-[20px] text-[#172550]">
            Geopathies and Electrosmog
          </h3>
        </div>
        <p class="text-[14px] text-[#3B3B3B] leading-relaxed">
          Natural and artificial radiation (Wi-Fi, mobile phones, high voltage
          lines) that alters the polarity of the blood etc...
        </p>
      </div>

      <div
        class="bg-white p-6 rounded-lg shadow-md border-l-4 border-[#158EC7] transition-transform hover:scale-105 flex flex-col"
      >
        <div class="flex items-center mb-2">
          <span class="text-2xl mr-2 text-[#158EC7]">🤧</span>
          <h3 class="font-bold text-[20px] text-[#172550]">
            Intolerances and Allergies
          </h3>
        </div>
        <p class="text-[14px] text-[#3B3B3B] leading-relaxed">
          Sensitivities to wheat, milk and lactose, pollens and more than 1,000
          testable substances etc...
        </p>
      </div>

      <div
        class="bg-white p-6 rounded-lg shadow-md border-l-4 border-[#FAB604] transition-transform hover:scale-105 flex flex-col"
      >
        <div class="flex items-center mb-2">
          <span class="text-2xl mr-2 text-[#FAB604]">🩹</span>
          <h3 class="font-bold text-[20px] text-[#172550]">Scars</h3>
        </div>
        <p class="text-[14px] text-[#3B3B3B] leading-relaxed">
          Thick or fine scars that act as interference foci affecting distant
          organs etc...
        </p>
      </div>

      <div
        class="bg-white p-6 rounded-lg shadow-md border-l-4 border-[#172550] transition-transform hover:scale-105 flex flex-col"
      >
        <div class="flex items-center mb-2">
          <span class="text-2xl mr-2 text-[#172550]">腸</span>
          <h3 class="font-bold text-[20px] text-[#172550]">
            Intestinal and Nutritional Dysbiosis
          </h3>
        </div>
        <p class="text-[14px] text-[#3B3B3B] leading-relaxed">
          Improvement of intestinal dysbiosis and correction of vitamin, mineral
          and amino acid deficiencies etc...
        </p>
      </div>
    </div>
  </section>

  <!-- Equilibrium -->
  <section class="max-w-[1200px] mx-auto py-12 px-4 text-center">
    <h2
      class="text-brand-primary font-heading font-bold text-[30px] md:text-[45px] uppercase tracking-[0.9px] mb-8"
    >
      Detoxification: Recover the Natural Balance of Your Body
    </h2>
    <div
      class="text-brand-text text-[17px] leading-[37px] font-body text-left max-w-[1000px] mx-auto space-y-4"
    >
      <p>
        Detoxification is an essential natural process, but often overloaded by
        continuous exposure to environmental, food, chemical, and
        electromagnetic toxins. Our medical treatment is not a simple
        'cleansing', but an advanced procedure that identifies and neutralizes
        the specific frequencies of toxic substances that interfere with the
        optimal functioning of your body. Restoring this balance is key to your
        overall health and vitality.
      </p>
    </div>
  </section>

  <!-- Frequency Simulation Canvas -->
  <section
    class="w-full bg-[#172550] py-12 px-4 text-center text-white relative"
  >
    <div
      class="max-w-[900px] mx-auto bg-[#172550] rounded-xl shadow-[0_4px_12px_rgba(0,0,0,0.1)] p-4 md:p-8"
    >
      <h2
        class="text-white font-heading font-bold text-[30px] leading-tight mb-4"
      >
        The Power of MORA Frequencies for Detoxification
      </h2>
      <p
        class="text-white font-body text-[16px] leading-[1.5] max-w-[600px] mx-auto mb-6"
      >
        Observe how harmonious frequencies (blue waves) interact and neutralize
        chaotic "toxins" (dark circles), restoring balance and energetic
        clarity. Vital "blood" particles (red) remain unaffected.
      </p>

      <button
        id="startButtonV3"
        class="bg-[#158EC7] hover:bg-[#1178A7] text-white py-3 px-6 rounded-lg font-semibold text-lg transition-colors mb-6 cursor-pointer"
      >
        Start Simulation
      </button>

      <canvas
        id="frequency-canvas-v3"
        class="w-full h-[400px] bg-white rounded-lg border border-[#CFD4D9] block mx-auto"
      ></canvas>

      <div
        class="flex flex-wrap justify-center gap-6 mt-6 pt-4 border-t border-white/20"
      >
        <div class="flex items-center text-sm">
          <div
            class="w-[18px] h-[18px] rounded-full border border-white/30 mr-2"
            style="background-color: #3B2F2F;"
          >
          </div>
          Toxins
        </div>
        <div class="flex items-center text-sm">
          <div
            class="w-[18px] h-[18px] rounded-full border border-white/30 mr-2"
            style="background-color: #B20710;"
          >
          </div>
          Blood Cells
        </div>
        <div class="flex items-center text-sm">
          <div
            class="w-[18px] h-[18px] rounded-full mr-2"
            style="background-color: rgba(100, 100, 100, 0.1); border: 1px dashed #999;"
          >
          </div>
          Neutralized Toxins
        </div>
        <div class="flex items-center text-sm">
          <div
            class="w-[25px] h-[2px] rounded-sm mr-2"
            style="background-color: #158EC7;"
          >
          </div>
          Frequency Waves
        </div>
      </div>
    </div>
  </section>

  <!-- Simplicity -->
  <section class="max-w-[1200px] mx-auto py-16 px-4 text-center">
    <h2
      class="text-brand-primary font-heading font-bold text-[30px] md:text-[45px] uppercase tracking-[0.9px] mb-8"
    >
      Your Detoxification Treatment: Simple and Effective
    </h2>
    <div
      class="text-brand-text text-[17px] leading-[37px] font-body text-left max-w-[1000px] mx-auto space-y-4"
    >
      <p>
        Just like our renowned stop-smoking treatment, the entire advanced
        medical detoxification process is carried out efficiently. We use
        state-of-the-art bio-frequency technology, a non-invasive and totally
        personalized method to address the specific needs detected in your body.
      </p>
    </div>
  </section>

  <!-- How It Works Flow -->
  <section class="max-w-[1200px] mx-auto px-4 pb-16 font-body">
    <div
      class="bg-white p-6 md:p-10 rounded-lg shadow-lg max-w-[80rem] mx-auto"
    >
      <p
        class="text-lg text-center leading-relaxed mb-10 break-words text-[#3B3B3B]"
      >
        MORA Bio-resonance is a biophysical therapy that uses the patient's own
        electromagnetic oscillations. It does not introduce external energy, but
        "re-calibrates" cellular communication to activate self-healing.
      </p>
      <div
        class="flex flex-col md:flex-row items-center justify-around gap-y-8 md:gap-y-0 md:gap-x-4"
      >
        <div class="flex flex-col items-center text-center">
          <div class="p-4 bg-[#F3F4F6] rounded-full mb-3">
            <span class="text-4xl leading-tight text-[#158EC7]">📡</span>
          </div>
          <h4 class="font-bold text-xl text-[#172550]">1. Reading</h4>
          <p class="mt-1 max-w-[20rem] text-[#3B3B3B]">
            The MORA-Nova device reads the full spectrum of energetic
            frequencies of the body through high-conductivity electrodes.
          </p>
        </div>

        <div class="text-4xl text-[#158EC7] rotate-90 md:rotate-0">→</div>

        <div class="flex flex-col items-center text-center">
          <div class="p-4 bg-[#F3F4F6] rounded-full mb-3">
            <span class="text-4xl leading-tight text-[#158EC7]">🔬</span>
          </div>
          <h4 class="font-bold text-xl text-[#172550]">2. Filtering</h4>
          <p class="mt-1 max-w-[20rem] text-[#3B3B3B]">
            A biological filter separates harmonic (healthy) frequencies from
            inharmonic (pathological) ones caused by toxins and pathogens.
          </p>
        </div>

        <div class="text-4xl text-[#158EC7] rotate-90 md:rotate-0">→</div>

        <div class="flex flex-col items-center text-center">
          <div class="p-4 bg-[#F3F4F6] rounded-full mb-3">
            <span class="text-4xl leading-tight text-[#158EC7]">🔄</span>
          </div>
          <h4 class="font-bold text-xl text-[#172550]">3. Neutralization</h4>
          <p class="mt-1 max-w-[20rem] text-[#3B3B3B]">
            Pathological frequencies are inverted electronically (mirror image)
            and returned to the body to cancel out toxic information.
          </p>
        </div>

        <div class="text-4xl text-[#158EC7] rotate-90 md:rotate-0">→</div>

        <div class="flex flex-col items-center text-center">
          <div class="p-4 bg-[#F3F4F6] rounded-full mb-3">
            <span class="text-4xl leading-tight text-[#158EC7]">✨</span>
          </div>
          <h4 class="font-bold text-xl text-[#172550]">4. Strengthening</h4>
          <p class="mt-1 max-w-[20rem] text-[#3B3B3B]">
            Simultaneously, healthy frequencies are amplified and reintroduced,
            strengthening the body's self-regulation capacity.
          </p>
        </div>
      </div>
    </div>
  </section>

  <MainTreatments />
  <Locations />

  <ContactSection />

  <!-- Script for Canvas Simulation -->
  <script is:inline>
    // Only run on client-side
    document.addEventListener("DOMContentLoaded", () => {
      const canvas = document.getElementById("frequency-canvas-v3");
      if (!canvas) return;
      const ctx = canvas.getContext("2d");
      const startButton = document.getElementById("startButtonV3");

      let animationFrameId;
      let isSimulationRunning = false;
      let toxinSpawningActive = false; // Flag to control toxin generation during the initial period
      let particles = [];
      const frequencyWaves = [];
      let simulationStartTime = 0; // To track when the simulation started

      const numToxinParticles = 59; // Reduced by 30% from 84 (84 * 0.70 = 58.8 rounded up)
      const numBloodParticles = 27; // Increased by 30% from 21 (21 * 1.30 = 27.3 rounded down)
      const waveSpawnInterval = 1500; // Intervalo entre ondas para un efecto más espaciado
      let lastWaveTime = 0;

      const TOXIN_SPAWNING_DURATION_MS = 12000; // Toxins spawn gradually for 12 seconds
      const SIMULATION_TOTAL_DURATION_MS = 35000; // Total simulation run time (35 seconds)
      const TOXIN_RESPAWN_CHANCE = 0.8; // Increased chance for gradual spawning, making them much more visible
      const BLOOD_PULSE_SPEED = 0.02; // Adjusted for more subtle pulsation
      const BLOOD_FLOW_SPEED = 1.5;
      const TOXIN_FLOW_SPEED = 1.0;

      // Define how fast neutralized toxins fade out (over 6 seconds)
      const NEUTRALIZED_FADE_DURATION_MS = 6000;
      const NEUTRALIZED_START_ALPHA = 0.6; // Starting alpha for neutralized toxins
      const NEUTRALIZED_ALPHA_DECREASE_PER_FRAME =
        NEUTRALIZED_START_ALPHA / (NEUTRALIZED_FADE_DURATION_MS / (1000 / 60)); // Assuming ~60fps

      const colors = {
        primary: "#172550",
        secondary: "#158EC7",
        accent: "#FAB604",
        text: "#3B3B3B",
        toxinColors: ["#3B2F2F", "#000000", "#5D3587"],
        neutralized: "rgba(100, 100, 100, 0.6)", // Semi-transparent when neutralized (0.6 opacity)
        wave: "rgba(21, 142, 199, 0.6)",
        blood: "#B20710",
        neutralizationFlash: "rgba(255, 255, 150, 0.8)",
      };

      const resizeCanvas = () => {
        canvas.width = canvas.offsetWidth;
        canvas.height = canvas.offsetHeight;
        // On resize, if simulation is running, re-initialize to adapt particle positions
        if (isSimulationRunning) {
          // Keep current number of blood and toxin particles, but reposition them
          const currentBloodCount = particles.filter(
            (p) => p.type === "blood",
          ).length;
          const currentToxinCount = particles.filter(
            (p) => p.type === "toxin",
          ).length; // Filter by type only, not removed
          initializeParticles(currentBloodCount, currentToxinCount); // Re-initialize based on current counts
        } else {
          // Only initialize blood particles on initial load or if simulation is not running
          initializeParticles(numBloodParticles, 0);
          setTimeout(() => {
            // slight delay mostly for Astro dom load timing
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach((p) => p.draw());
          }, 100);
        }
      };

      window.addEventListener("resize", resizeCanvas);

      class Particle {
        constructor(x, y, radius, type, color) {
          this.x = x;
          this.y = y;
          this.radius = radius;
          this.type = type;
          this.color = color; // Initial color (fully opaque)
          if (this.type === "blood") {
            this.vx = BLOOD_FLOW_SPEED + (Math.random() - 0.5) * 0.5;
            this.vy = (Math.random() - 0.5) * 1;
          } else {
            // toxin
            this.vx = TOXIN_FLOW_SPEED + (Math.random() - 0.5) * 1;
            this.vy = (Math.random() - 0.5) * 1;
          }
          this.isNeutralized = false;
          this.alpha = 1; // Starts fully opaque
          this.flashAlpha = 0;
          this.flashRadius = 0;
          this.bloodPulseFactor = 1;
          this.bloodPulseDirection = 1;
        }

        draw() {
          ctx.beginPath();
          ctx.arc(
            this.x,
            this.y,
            this.radius * this.bloodPulseFactor,
            0,
            Math.PI * 2,
          );
          // Use initial color if not neutralized, otherwise use neutralized color and its current fading alpha
          ctx.fillStyle = this.isNeutralized ? colors.neutralized : this.color;
          ctx.globalAlpha = this.alpha; // Use the particle's current alpha value for drawing
          ctx.fill();

          ctx.strokeStyle = "#333333"; // Dark grey border
          ctx.lineWidth = 1; // 1 pixel border
          ctx.stroke();

          if (this.flashAlpha > 0) {
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.flashRadius, 0, Math.PI * 2);
            ctx.fillStyle = colors.neutralizationFlash;
            ctx.globalAlpha = this.flashAlpha;
            ctx.fill();
          }
          ctx.globalAlpha = 1; // Reset global alpha after drawing particle and flash
        }

        update() {
          // Particle wrapping logic
          if (this.x - this.radius > canvas.width) {
            this.x = -this.radius;
            this.y = Math.random() * canvas.height;
          } else if (this.x + this.radius < 0) {
            this.x = canvas.width + this.radius;
          }

          if (
            this.y + this.radius > canvas.height ||
            this.y - this.radius < 0
          ) {
            this.vy *= -1;
          }

          this.x += this.vx;
          this.y += this.vy;

          if (this.type === "toxin") {
            if (!this.isNeutralized) {
              // Random subtle changes in velocity for chaotic movement (for non-neutralized toxins)
              this.vx += (Math.random() - 0.5) * 0.1;
              this.vy += (Math.random() - 0.5) * 0.1;
            } else {
              // If already neutralized, continue flow but with slightly less erratic movement
              this.vx = TOXIN_FLOW_SPEED; // Maintain base flow speed
              this.vy *= 0.95; // Slightly damp vertical movement

              // Gradually fade out
              this.alpha -= NEUTRALIZED_ALPHA_DECREASE_PER_FRAME;
              if (this.alpha <= 0) {
                this.removed = true; // Mark for removal once fully faded
              }
            }
          }

          const maxRandomSpeed = 1;
          if (this.type === "blood") {
            this.vx =
              BLOOD_FLOW_SPEED +
              Math.min(
                Math.max(this.vx - BLOOD_FLOW_SPEED, -maxRandomSpeed),
                maxRandomSpeed,
              );
            this.vy = Math.min(
              Math.max(this.vy, -maxRandomSpeed),
              maxRandomSpeed,
            );
          } else {
            // toxin
            this.vx =
              TOXIN_FLOW_SPEED +
              Math.min(
                Math.max(this.vx - TOXIN_FLOW_SPEED, -maxRandomSpeed),
                maxRandomSpeed,
              );
            this.vy = Math.min(
              Math.max(this.vy, -maxRandomSpeed),
              maxRandomSpeed,
            );
          }

          if (this.flashAlpha > 0) {
            this.flashAlpha -= 0.05;
            this.flashRadius += 2;
          }

          if (this.type === "blood") {
            this.bloodPulseFactor +=
              BLOOD_PULSE_SPEED * this.bloodPulseDirection;
            // Adjusted pulse range for subtlety
            if (this.bloodPulseFactor > 1.05 || this.bloodPulseFactor < 0.95) {
              // Smaller pulse range
              this.bloodPulseDirection *= -1;
            }
          }
        }

        triggerFlash() {
          this.flashAlpha = 1;
          this.flashRadius = this.radius;
          if (this.type === "toxin") {
            this.alpha = NEUTRALIZED_START_ALPHA; // Set initial alpha for fading
          }
        }
      }

      class FrequencyWave {
        constructor(color) {
          this.x = canvas.width; // Start from the right edge
          this.width = 30; // Ancho de la barra de la ola
          this.color = color;
          this.opacity = 1;
          this.speed = 4; // Velocidad de desplazamiento de la ola hacia la izquierda
          this.active = true;
          this.neutralizedCount = 0;
        }

        draw() {
          ctx.fillStyle = this.color;
          ctx.globalAlpha = this.opacity;
          ctx.fillRect(this.x, 0, this.width, canvas.height); // Dibuja una barra vertical
          ctx.globalAlpha = 1;
        }

        update() {
          this.x -= this.speed; // La ola se mueve hacia la izquierda
          this.opacity -= 0.008; // Se desvanece lentamente

          if (this.opacity <= 0 || this.x + this.width < 0) {
            // Se desactiva una vez que sale de la pantalla por la izquierda
            this.active = false;
          }
        }
      }

      // Function to initialize particles for the very start or for a full reset
      function initializeParticles(numBlood, numToxins) {
        particles = []; // Clear existing particles
        // Create blood particles
        for (let i = 0; i < numBlood; i++) {
          particles.push(
            new Particle(
              Math.random() * canvas.width,
              Math.random() * canvas.height,
              Math.random() * 6 + 8, // Increased base radius for blood particles (8 to 14)
              "blood",
              colors.blood,
            ),
          );
        }
        // Create toxin particles (only if explicitly requested for initial full load, or for gradual spawning)
        for (let i = 0; i < numToxins; i++) {
          const randomColor =
            colors.toxinColors[
              Math.floor(Math.random() * colors.toxinColors.length)
            ];
          particles.push(
            new Particle(
              Math.random() * canvas.width, // Distribute initial toxins across width
              Math.random() * canvas.height,
              Math.random() * 5 + 5, // Increased base radius for toxin particles (5 to 10)
              "toxin",
              randomColor,
            ),
          );
        }
      }

      // Initial setup
      resizeCanvas();

      function animate(currentTime) {
        animationFrameId = requestAnimationFrame(animate);

        // Check if simulation duration has passed
        if (
          isSimulationRunning &&
          performance.now() - simulationStartTime > SIMULATION_TOTAL_DURATION_MS
        ) {
          cancelAnimationFrame(animationFrameId);
          isSimulationRunning = false;
          toxinSpawningActive = false; // Ensure spawning is off
          startButton.disabled = false; // Re-enable button to allow reset/restart

          // At the end, remove all toxins (including neutralized ones)
          particles = particles.filter((p) => p.type === "blood");
          frequencyWaves.length = 0; // Clear any remaining waves
          ctx.clearRect(0, 0, canvas.width, canvas.height); // Clear to show only blood particles
          particles.forEach((p) => p.draw()); // Draw remaining blood particles
          startButton.textContent = "Start Simulation"; // Reset button text
          return; // Stop the animation loop
        }

        ctx.clearRect(0, 0, canvas.width, canvas.height);

        // Generar nuevas olas desde la derecha
        if (
          isSimulationRunning &&
          currentTime - lastWaveTime > waveSpawnInterval
        ) {
          frequencyWaves.push(new FrequencyWave(colors.wave)); // La ola ahora se define solo por color
          lastWaveTime = currentTime;
        }

        particles.forEach((p) => {
          p.update();
          p.draw();
        });

        for (let i = frequencyWaves.length - 1; i >= 0; i--) {
          const wave = frequencyWaves[i];
          wave.update();
          if (wave.active) {
            wave.draw();
            let waveNeutralizedCount = 0;

            particles.forEach((p) => {
              if (p.type === "toxin" && !p.isNeutralized) {
                // Colisión para la barra vertical de la ola
                // La partícula está dentro del rango horizontal de la ola
                if (
                  p.x + p.radius > wave.x &&
                  p.x - p.radius < wave.x + wave.width
                ) {
                  p.isNeutralized = true;
                  p.triggerFlash();
                  waveNeutralizedCount++;
                }
              }
            });
            wave.neutralizedCount = waveNeutralizedCount;
          } else {
            frequencyWaves.splice(i, 1);
          }
        }
        // Filter out fully faded toxins
        particles = particles.filter((p) => !(p.type === "toxin" && p.removed));

        // Gradual toxin spawning during the initial duration (now up to 12 seconds)
        if (
          isSimulationRunning &&
          performance.now() - simulationStartTime < TOXIN_SPAWNING_DURATION_MS
        ) {
          const currentToxinParticlesCount = particles.filter(
            (p) => p.type === "toxin",
          ).length;
          if (currentToxinParticlesCount < numToxinParticles) {
            if (Math.random() < TOXIN_RESPAWN_CHANCE) {
              const randomColor =
                colors.toxinColors[
                  Math.floor(Math.random() * colors.toxinColors.length)
                ];
              particles.push(
                new Particle(
                  -5, // Always appear from the left, following the flow
                  Math.random() * canvas.height,
                  Math.random() * 5 + 5, // Base radius for toxin particles
                  "toxin",
                  randomColor,
                ),
              );
            }
          }
        }
      }

      startButton.addEventListener("click", () => {
        // If simulation is already running, stop and reset it
        if (isSimulationRunning) {
          cancelAnimationFrame(animationFrameId); // Stop current animation
          isSimulationRunning = false;
          toxinSpawningActive = false;
          startButton.disabled = false; // Re-enable the button
          initializeParticles(numBloodParticles, 0); // Reset to only blood particles
          frequencyWaves.length = 0; // Clear all waves
          ctx.clearRect(0, 0, canvas.width, canvas.height); // Clear canvas
          particles.forEach((p) => p.draw()); // Draw initial state
          startButton.textContent = "Start Simulation"; // Reset button text
          return;
        }

        // Start new simulation
        isSimulationRunning = true;
        toxinSpawningActive = true; // Activate toxin spawning for the initial duration
        startButton.disabled = true; // Disable button during simulation
        startButton.textContent = "Restart Simulation"; // Change button text

        // Initialize particles with blood and ZERO toxins initially, as they will spawn gradually
        initializeParticles(numBloodParticles, 0); // Start with 0 toxins, as they will spawn over time

        // Ensure initial positioning for blood particles (toxins will spawn from -5)
        particles.forEach((p) => {
          if (p.type === "blood") {
            p.x = Math.random() * canvas.width; // Blood can be anywhere initially
          }
        });
        frequencyWaves.length = 0; // Clear any old waves

        simulationStartTime = performance.now(); // Record start time for duration check
        lastWaveTime = simulationStartTime; // Initialize lastWaveTime for immediate first wave

        animate(0); // Start the animation loop
      });
    });
  </script>
</Layout>
