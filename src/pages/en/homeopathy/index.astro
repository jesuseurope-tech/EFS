---
import Layout from "../../../layouts/Layout.astro";
import ContactSection from "../../../components/ContactSection.astro";
import { getLangFromUrl } from "../../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
---

<Layout title="Homeopathy" lang={lang}>
  <!-- Hero Section with Background -->
  <section
    class="bg-[url('/images/pages/homeopatia-hero.jpeg')] bg-center bg-cover bg-no-repeat w-full min-h-[500px] flex items-end"
  >
    <div class="max-w-[1200px] w-full mx-auto px-4 py-20 text-center">
      <h1
        class="text-white font-heading font-bold text-[30px] md:text-[42px] uppercase tracking-[0.9px]"
      >
        Doctor and homeopath
      </h1>
    </div>
  </section>

  <!-- Intro Block -->
  <section
    class="max-w-[1200px] mx-auto py-12 px-4 flex flex-col md:flex-row items-center gap-8"
  >
    <div class="w-full md:w-2/5 flex justify-center">
      <img
        src="/images/team/enrique.png"
        alt="Dr. Enrique Fernandez"
        class="max-w-full h-auto"
      />
    </div>
    <div
      class="w-full md:w-3/5 text-center md:text-left text-brand-text font-body text-[20px] md:text-[31px] font-medium leading-[1.6]"
    >
      <p>
        With more than forty years of dedication to Medicine, I offer you deeply
        personalized medical attention for you, your children and your family.
      </p>
    </div>
  </section>

  <!-- Feature 4 columns -->
  <section
    class="max-w-[1200px] mx-auto flex flex-col md:flex-row gap-6 px-4 py-12"
  >
    <div class="w-full md:w-1/4 text-center">
      <h3
        class="font-heading text-[20px] md:text-[25px] font-medium text-[#158EC7] mb-2 font-['Open_Sans']"
      >
        Deep Experience
      </h3>
      <p class="font-body text-[16px] text-brand-text leading-[28px]">
        More than 40 years dedicated to homeopathy to restore your health and
        comprehensive well-being.
      </p>
    </div>
    <div class="w-full md:w-1/4 text-center">
      <h3
        class="font-heading text-[20px] md:text-[25px] font-medium text-[#158EC7] mb-2 font-['Open_Sans']"
      >
        Personal Attention
      </h3>
      <p class="font-body text-[16px] text-brand-text leading-[28px]">
        Detailed consultations (1-3h) to understand your unique case and treat
        the root cause of your ailments.
      </p>
    </div>
    <div class="w-full md:w-1/4 text-center">
      <h3
        class="font-heading text-[20px] md:text-[25px] font-medium text-[#158EC7] mb-2 font-['Open_Sans']"
      >
        Holistic Approach
      </h3>
      <p class="font-body text-[16px] text-brand-text leading-[28px]">
        We treat you in your totality (body, mind, emotions) to find your
        natural and lasting balance.
      </p>
    </div>
    <div class="w-full md:w-1/4 text-center">
      <h3
        class="font-heading text-[20px] md:text-[25px] font-medium text-[#158EC7] mb-2 font-['Open_Sans']"
      >
        Natural Healing
      </h3>
      <p class="font-body text-[16px] text-brand-text leading-[28px]">
        We stimulate your own healing capacity to achieve a well-being that is
        respectful to your organism.
      </p>
    </div>
  </section>

  <!-- La homeopatia -->
  <section class="max-w-[1200px] mx-auto py-12 px-4 text-center">
    <h2
      class="text-brand-primary font-heading font-bold text-[30px] md:text-[45px] uppercase tracking-[0.9px] mb-8"
    >
      Homeopathy
    </h2>
    <div
      class="text-brand-text text-[17px] leading-[37px] font-body text-left max-w-[1000px] mx-auto space-y-4"
    >
      <p>
        Homeopathy is a medical discipline with foundations dating back to
        Hippocrates and which was systematized by Dr. Samuel Christian Hahnemann
        in 1808. It is a therapeutic medical science based on rigorous clinical
        observation and profound respect for the natural laws of healing of the
        organism itself.
      </p>
      <p>
        In my practice, with more than 40 years of experience, I apply
        Homeopathy as a precision medical tool. The goal is not to suppress
        symptoms, but <strong
          >to restore the organism's inherent self-regulation capacity</strong
        >, rebalancing the affected systems and organs to achieve a stable and
        lasting state of health. We treat the &laquo;Human Being&raquo; in their
        entirety, understanding that their physical, mental, and emotional
        dimension is indivisible.
      </p>
    </div>
  </section>

  <!-- Ser Humano Quote Block -->
  <section class="max-w-[1200px] mx-auto py-[50px] px-4">
    <p
      class="text-[35px] font-heading font-light text-brand-text text-center uppercase tracking-[0.9px]"
    >
      The <span class="font-serif italic font-light normal-case"
        >Human Being</span
      > in you must be treated
    </p>
  </section>

  <!-- Principio de similitud -->
  <section class="max-w-[1200px] mx-auto py-12 px-4">
    <div
      class="text-brand-text text-[17px] leading-[37px] font-body text-left max-w-[1000px] mx-auto space-y-4"
    >
      <h4
        class="font-body text-[25px] font-bold text-brand-text mb-4 font-['Open_Sans']"
      >
        The Principle of Similitude: The Therapeutic Key
      </h4>
      <p>
        The fundamental pillar of Homeopathy is the <strong
          >Principle of Similitude</strong
        >: &laquo;like cures like&raquo;. This phenomenon, already described by
        Hippocrates and Paracelsus, was experimentally proven by Dr. Hahnemann
        and establishes that a substance capable of causing certain symptoms in
        a healthy individual can, in infinitesimal and specifically prepared
        doses, cure those same symptoms in a sick person.
      </p>
      <p>
        The phenomenon of similitude is observed in numerous areas, including
        certain conventional medications. It is based on the fact that the same
        substance can have different or opposite effects depending on the dose
        used and the subject's sensitivity. This fact was described by
        Hippocrates, reformulated by Paracelsus and proven by Hahnemann, thus
        giving rise to one of the principles of Homeopathy.
      </p>
    </div>
  </section>

  <!-- El arte de la homeopatía -->
  <section class="bg-brand-secondary py-12 px-4 mt-8">
    <h2
      class="text-white font-heading font-bold text-[30px] md:text-[45px] uppercase tracking-[0.9px] text-center mb-0"
    >
      The art of homeopathy
    </h2>
  </section>

  <!-- Gradient section with shape divider -->
  <section
    class="relative bg-gradient-to-br from-[#172550] to-[#158ec7] pb-12 w-full pt-12 overflow-hidden px-4 md:px-0"
  >
    <!-- Shape Divider using custom SVGs (tilt) -->
    <div
      class="absolute top-0 left-0 w-full overflow-hidden leading-zero"
      style="transform: rotate(180deg);"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1000 100"
        preserveAspectRatio="none"
        class="block w-[calc(100%+1.3px)] h-[100px] relative left-1/2 -translate-x-1/2"
        style="fill: #158EC7;"
      >
        <path d="M0,6V0h1000v100L0,6z"></path>
      </svg>
    </div>
    <div class="max-w-[1200px] mx-auto relative z-10 pt-[50px]">
      <div
        class="bg-white rounded-[30px] p-8 md:p-12 mb-12 shadow-lg max-w-[900px] mx-auto text-brand-text text-[17px] leading-[37px] font-body text-center space-y-4"
      >
        <p>
          In high-level homeopathic medicine, our clinical work consists of
          carrying out a <strong
            >deep synthesis of all the facets that make up the person</strong
          >.
        </p>
        <p>
          We will talk about your <strong>physical</strong> plane (specific symptoms,
          their modalities), your <strong>emotional</strong> plane (fears, sadness,
          anxieties), your <strong>mental</strong> plane (thought patterns, concentration)
          and even your <strong>spiritual</strong> plane (your sense of purpose, your
          vital conflicts).
        </p>
        <p>
          The objective of this exhaustive investigation is to find <strong
            >the unique remedy (or <em>simillimum</em>)</strong
          > that resonates with your entire being. This remedy acts as a catalyst
          that initiates the self-healing process, stimulating the body's vital force.
        </p>
      </div>

      <div class="flex justify-center max-w-[800px] mx-auto">
        <img
          src="/images/pages/homeopatia-article.jpeg"
          alt="Medicine bottles"
          class="max-w-[800px] w-full h-auto border-[5px] border-brand-primary rounded-[10px] shadow-lg"
        />
      </div>
    </div>
  </section>

  <!-- Areas de Aplicacion Accordion -->
  <section
    class="max-w-[1200px] mx-auto py-16 px-4 flex flex-col md:flex-row gap-8"
  >
    <div class="w-full md:w-1/3 flex justify-center items-start">
      <img
        src="/images/treatments/white-background-mobile.png"
        class="max-w-[300px] w-full"
        alt="Device illustration"
      />
    </div>
    <div class="w-full md:w-2/3">
      <h2
        class="text-brand-primary font-heading font-bold text-[30px] md:text-[45px] uppercase tracking-[0.9px] mb-8 text-center md:text-left"
      >
        Areas of application
      </h2>

      <div class="space-y-4">
        <details class="group bg-white border border-gray-200" open>
          <summary
            class="flex justify-between items-center font-body text-[16px] font-medium cursor-pointer list-none p-4 hover:bg-gray-50 transition-colors text-brand-text"
          >
            <span>Emotional and Mental Well-being</span>
            <span class="transition group-open:rotate-180">
              <svg
                class="w-4 h-4 fill-current text-brand-primary"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 448 512"
                ><path
                  d="M416 208H272V64c0-17.67-14.33-32-32-32h-32c-17.67 0-32 14.33-32 32v144H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h144v144c0 17.67 14.33 32 32 32h32c17.67 0 32-14.33 32-32V304h144c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z"
                  class="hidden group-open:block"></path><path
                  d="M416 208H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h384c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z"
                  class="block group-open:hidden"></path></svg
              >
            </span>
          </summary>
          <div
            class="p-4 border-t border-gray-200 text-brand-text font-body text-[17px] leading-[37px] bg-white text-left"
          >
            <ul class="list-disc ml-6 space-y-2">
              <li>
                Background treatment for <strong
                  >anxiety, fears, jealousy, depression or prolonged sadness</strong
                >, etc.
              </li>
              <li>
                Support for <strong
                  >behavioral, concentration or eating problems</strong
                >, both in adults and children, etc.
              </li>
              <li>
                Management of <strong
                  >stress, Post-Traumatic Stress Disorder,</strong
                > etc.
              </li>
            </ul>
          </div>
        </details>
        <details class="group bg-white border border-gray-200">
          <summary
            class="flex justify-between items-center font-body text-[16px] font-medium cursor-pointer list-none p-4 hover:bg-gray-50 transition-colors text-brand-text"
          >
            <span>Chronic and Recurrent Conditions</span>
            <span class="transition group-open:rotate-180">
              <svg
                class="w-4 h-4 fill-current text-brand-primary"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 448 512"
                ><path
                  d="M416 208H272V64c0-17.67-14.33-32-32-32h-32c-17.67 0-32 14.33-32 32v144H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h144v144c0 17.67 14.33 32 32 32h32c17.67 0 32-14.33 32-32V304h144c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z"
                  class="block group-open:hidden"></path><path
                  d="M416 208H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h384c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z"
                  class="hidden group-open:block"></path></svg
              >
            </span>
          </summary>
          <div
            class="p-4 border-t border-gray-200 text-brand-text font-body text-[17px] leading-[37px] bg-white text-left"
          >
            <ul class="list-disc ml-6 space-y-2">
              <li>
                <strong>Respiratory problems:</strong> Frequent colds, recurrent tonsillitis,
                asthma, etc.
              </li>
              <li>
                <strong>Skin conditions:</strong> Atopic dermatitis and other skin
                conditions, etc.
              </li>
              <li>
                <strong>Digestive disorders:</strong> Food intolerances, intestinal
                imbalances and much more, etc.
              </li>
            </ul>
          </div>
        </details>
        <details class="group bg-white border border-gray-200">
          <summary
            class="flex justify-between items-center font-body text-[16px] font-medium cursor-pointer list-none p-4 hover:bg-gray-50 transition-colors text-brand-text"
          >
            <span>Support in Serious Illnesses</span>
            <span class="transition group-open:rotate-180">
              <svg
                class="w-4 h-4 fill-current text-brand-primary"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 448 512"
                ><path
                  d="M416 208H272V64c0-17.67-14.33-32-32-32h-32c-17.67 0-32 14.33-32 32v144H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h144v144c0 17.67 14.33 32 32 32h32c17.67 0 32-14.33 32-32V304h144c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z"
                  class="block group-open:hidden"></path><path
                  d="M416 208H32c-17.67 0-32 14.33-32 32v32c0 17.67 14.33 32 32 32h384c17.67 0 32-14.33 32-32v-32c0-17.67-14.33-32-32-32z"
                  class="hidden group-open:block"></path></svg
              >
            </span>
          </summary>
          <div
            class="p-4 border-t border-gray-200 text-brand-text font-body text-[17px] leading-[37px] bg-white text-left"
          >
            <ul class="list-disc ml-6 space-y-2">
              <li>
                Protocols to <strong
                  >alleviate the side effects of chemotherapy</strong
                > and other oncological treatments, improving the patient's quality
                of life, etc.
              </li>
              <li>
                Treatment to counteract the <strong
                  >adverse effects of drugs or post-vaccine sequelae</strong
                >, including those related to Covid-19 (Persistent Covid), etc.
              </li>
            </ul>
          </div>
        </details>
      </div>

      <div class="mt-6 text-brand-text font-body text-[17px] leading-[37px]">
        <p>
          <em
            >(This list is merely indicative, since the individualized approach
            of homeopathy allows addressing practically any imbalance in which
            the organism needs a boost to recover its state of health.)</em>
        </p>
      </div>
    </div>
  </section>

  <!-- Principales Tratamientos Menu Block -->
  <section class="max-w-[1200px] mx-auto py-12 px-4 border-t border-gray-100">
    <h2
      class="text-[30px] font-heading font-bold text-brand-primary uppercase text-center tracking-[0.9px] mb-12"
    >
      Our Main Treatments
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Item 1 -->
      <a
        href="/en/homeopathy/"
        class="group block text-center p-6 bg-white shadow-sm border border-gray-50 rounded transition-transform hover:-translate-y-1"
      >
        <div
          class="mx-auto w-[60px] h-[60px] flex items-center justify-center rounded-full border-2 border-brand-primary text-brand-primary group-hover:bg-brand-accent group-hover:border-brand-accent group-hover:text-white transition-colors mb-4"
        >
          <svg
            class="w-8 h-8 fill-current"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 576 512"
            ><path
              d="M546.2 9.7c-5.6-12.5-21.6-13-28.3-1.2C486.9 62.4 431.4 96 368 96h-80C182 96 96 182 96 288c0 7 .8 13.7 1.5 20.5C161.3 262.8 253.4 224 384 224c8.8 0 16 7.2 16 16s-7.2 16-16 16C132.6 256 26 410.1 2.4 468c-6.6 16.3 1.2 34.9 17.5 41.6 16.4 6.8 35-1.1 41.8-17.3 1.5-3.6 20.9-47.9 71.9-90.6 32.4 43.9 94 85.8 174.9 77.2C465.5 467.5 576 326.7 576 154.3c0-50.2-10.8-102.2-29.8-144.6z"
            ></path></svg
          >
        </div>
        <h3
          class="text-[20px] font-heading font-medium text-brand-text group-hover:text-brand-accent transition-colors mb-2"
        >
          Homeopathic Medicine
        </h3>
        <p class="font-body text-[15px] text-gray-500 leading-snug">
          Recover your health addressing the root of your diseases.
        </p>
      </a>
      <!-- Item 2 -->
      <a
        href="/en/stop-smoking/"
        class="group block text-center p-6 bg-white shadow-sm border border-gray-50 rounded transition-transform hover:-translate-y-1"
      >
        <div
          class="mx-auto w-[60px] h-[60px] flex items-center justify-center rounded-full border-2 border-brand-primary text-brand-primary group-hover:bg-brand-accent group-hover:border-brand-accent group-hover:text-white transition-colors mb-4"
        >
          <svg
            class="w-8 h-8 fill-current"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 512 512"
            ><path
              d="M96 304c0 8.8 7.2 16 16 16h117.5l-96-96H112c-8.8 0-16 7.2-16 16v64zM256 0C114.6 0 0 114.6 0 256s114.6 256 256 256 256-114.6 256-256S397.4 0 256 0zm0 448c-105.9 0-192-86.1-192-192 0-41.4 13.3-79.7 35.7-111.1l267.4 267.4C335.7 434.7 297.4 448 256 448zm45.2-192H384v32h-50.8l-32-32zm111.1 111.1L365.2 320H400c8.8 0 16-7.2 16-16v-64c0-8.8-7.2-16-16-16H269.2L144.9 99.7C176.3 77.3 214.6 64 256 64c105.9 0 192 86.1 192 192 0 41.4-13.3 79.7-35.7 111.1zM320.6 128c-15.6 0-28.6-11.2-31.4-25.9-.7-3.6-4-6.1-7.7-6.1h-16.2c-5 0-8.7 4.5-8 9.4 4.6 30.9 31.2 54.6 63.3 54.6 15.6 0 28.6 11.2 31.4 25.9.7 3.6 4 6.1 7.7 6.1h16.2c5 0 8.7-4.5 8-9.4-4.6-30.9-31.2-54.6-63.3-54.6z"
            ></path></svg
          >
        </div>
        <h3
          class="text-[20px] font-heading font-medium text-brand-text group-hover:text-brand-accent transition-colors mb-2"
        >
          Stop Smoking Treatment
        </h3>
        <p class="font-body text-[15px] text-gray-500 leading-snug">
          Quit smoking in a single session. Natural and effective with
          bio-frequencies.
        </p>
      </a>
      <!-- Item 3 -->
      <a
        href="/en/detoxification/"
        class="group block text-center p-6 bg-white shadow-sm border border-gray-50 rounded transition-transform hover:-translate-y-1"
      >
        <div
          class="mx-auto w-[60px] h-[60px] flex items-center justify-center rounded-full border-2 border-brand-primary text-brand-primary group-hover:bg-brand-accent group-hover:border-brand-accent group-hover:text-white transition-colors mb-4"
        >
          <svg
            class="w-8 h-8 fill-current"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 576 512"
            ><path
              d="M562.1 383.9c-21.5-2.4-42.1-10.5-57.9-22.9-14.1-11.1-34.2-11.3-48.2 0-37.9 30.4-107.2 30.4-145.7-1.5-13.5-11.2-33-9.1-46.7 1.8-38 30.1-106.9 30-145.2-1.7-13.5-11.2-33.3-8.9-47.1 2-15.5 12.2-36 20.1-57.7 22.4-7.9.8-13.6 7.8-13.6 15.7v32.2c0 9.1 7.6 16.8 16.7 16 28.8-2.5 56.1-11.4 79.4-25.9 56.5 34.6 137 34.1 192 0 56.5 34.6 137 34.1 192 0 23.3 14.2 50.9 23.3 79.1 25.8 9.1.8 16.7-6.9 16.7-16v-31.6c.1-8-5.7-15.4-13.8-16.3zm0-144c-21.5-2.4-42.1-10.5-57.9-22.9-14.1-11.1-34.2-11.3-48.2 0-37.9 30.4-107.2 30.4-145.7-1.5-13.5-11.2-33-9.1-46.7 1.8-38 30.1-106.9 30-145.2-1.7-13.5-11.2-33.3-8.9-47.1 2-15.5 12.2-36 20.1-57.7 22.4-7.9.8-13.6 7.8-13.6 15.7v32.2c0 9.1 7.6 16.8 16.7 16 28.8-2.5 56.1-11.4 79.4-25.9 56.5 34.6 137 34.1 192 0 56.5 34.6 137 34.1 192 0 23.3 14.2 50.9 23.3 79.1 25.8 9.1.8 16.7-6.9 16.7-16v-31.6c.1-8-5.7-15.4-13.8-16.3zm0-144C540.6 93.4 520 85.4 504.2 73 490.1 61.9 470 61.7 456 73c-37.9 30.4-107.2 30.4-145.7-1.5-13.5-11.2-33-9.1-46.7 1.8-38 30.1-106.9 30-145.2-1.7-13.5-11.2-33.3-8.9-47.1 2-15.5 12.2-36 20.1-57.7 22.4-7.9.8-13.6 7.8-13.6 15.7v32.2c0 9.1 7.6 16.8 16.7 16 28.8-2.5 56.1-11.4 79.4-25.9 56.5 34.6 137 34.1 192 0 56.5 34.6 137 34.1 192 0 23.3 14.2 50.9 23.3 79.1 25.8 9.1.8 16.7-6.9 16.7-16v-31.6c.1-8-5.7-15.4-13.8-16.3z"
            ></path></svg
          >
        </div>
        <h3
          class="text-[20px] font-heading font-medium text-brand-text group-hover:text-brand-accent transition-colors mb-2"
        >
          Complete Detoxification
        </h3>
        <p class="font-body text-[15px] text-gray-500 leading-snug">
          Free your body from toxics, bacterial and viral loads, vaccine side
          effects and persistent Covid.
        </p>
      </a>
      <!-- Item 4 -->
      <a
        href="/en/family-medicine/"
        class="group block text-center p-6 bg-white shadow-sm border border-gray-50 rounded transition-transform hover:-translate-y-1"
      >
        <div
          class="mx-auto w-[60px] h-[60px] flex items-center justify-center rounded-full border-2 border-brand-primary text-brand-primary group-hover:bg-brand-accent group-hover:border-brand-accent group-hover:text-white transition-colors mb-4"
        >
          <svg
            class="w-8 h-8 fill-current"
            xmlns="http://www.w3.org/2000/svg"
