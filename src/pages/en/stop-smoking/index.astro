---
import Layout from "../../../layouts/Layout.astro";
import ContactSection from "../../../components/ContactSection.astro";
import { getLangFromUrl } from "../../../i18n/utils";
import Locations from "../../../components/Locations.astro";

const lang = getLangFromUrl(Astro.url);
---

<Layout title="Stop Smoking Treatment" lang={lang}>
  <!-- Hero Section 2 -->
  <section
    class="bg-[#0C1124] min-h-[600px] flex items-center relative py-20 overflow-hidden"
  >
    <!-- Background Image -->
    <div
      class="absolute inset-0 w-full h-full bg-[url('/images/pages/quit-smoking.png')] bg-contain bg-center bg-no-repeat opacity-[0.51] md:-ml-[20%]"
    >
    </div>

    <div
      class="max-w-[1200px] w-full mx-auto px-4 relative z-10 flex flex-col md:flex-row"
    >
      <div class="w-full md:w-[52%]">
        <h1
          class="text-white font-heading font-bold uppercase text-[32px] md:text-[41px] leading-[1.2] md:leading-[49px] tracking-[0.9px] mb-[101px]"
        >
          If you want, quitting is easy.
        </h1>
        <div class="bg-[#0c1124ab] p-6 text-right md:bg-transparent md:p-0">
          <h4
            class="text-white font-accent font-light italic text-[20px] md:text-[25px]"
          >
            Detoxification treatment completely nullifying the addictive effect
            of nicotine and tobacco toxins.
          </h4>
        </div>
      </div>
    </div>
  </section>

  <!-- Una sola sesión -->
  <section
    class="max-w-[1200px] mx-auto pt-[75px] pb-[55px] px-4 md:px-[55px] text-center"
  >
    <h2
      class="text-brand-primary font-heading font-bold text-[24px] md:text-[30px] uppercase mb-4"
    >
      A single session, of one hour
    </h2>
    <p class="text-[#023047] font-body text-[28px] md:text-[38px] font-light">
      You just have to want it
    </p>
  </section>

  <!-- 95% exito -->
  <section
    class="max-w-[1200px] mx-auto flex flex-col md:flex-row gap-8 px-4 py-10"
  >
    <div class="w-full md:w-[40%] flex flex-col justify-center items-center">
      <div class="text-center">
        <h3
          class="text-brand-secondary font-heading font-bold text-[24px] md:text-[30px] uppercase"
        >
          success rate!
        </h3>
        <div
          class="text-brand-accent font-heading font-semibold text-[80px] md:text-[100px] uppercase leading-none"
        >
          95%
        </div>
      </div>
    </div>
    <div
      class="w-full md:w-[60%] flex flex-col justify-center text-left text-brand-text text-[17px] leading-[37px]"
    >
      <h3 class="text-brand-secondary font-heading font-bold text-[25px] mb-4">
        Bio-Resonance Treatment
      </h3>
      <p class="font-body">
        The application of bio-resonance to quit smoking is based on the
        physical principle that the body (its cells) is permeated by tobacco
        smoke and thus «<b>memorizes</b>» and retains the <b
          >electromagnetic frequencies</b
        > of the toxic substances it has consumed, such as nicotine, tar, and other
        cigarette additives. Our treatment helps the organism to <b
          >neutralize</b
        > and <b>eliminate</b> these toxic frequencies, facilitating detoxification
        and removing the memory and information of the substances, allowing the patient
        to <b>quit smoking</b>.
      </p>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="max-w-[1200px] mx-auto flex flex-col md:flex-row py-10">
    <div
      class="w-full md:w-1/4 p-6 md:p-10 text-brand-text text-[17px] leading-[37px]"
    >
      <h4
        class="font-bold mb-4 font-body text-[20px] md:text-[25px] text-brand-text"
      >
        Fast and effective efficiency
      </h4>
      <p class="text-center md:text-left">
        Our experience confirms that a single session eliminates tobacco
        dependence, making it the best option for those seeking results.
      </p>
    </div>
    <div
      class="w-full md:w-1/4 p-6 md:p-10 text-brand-text text-[17px] leading-[37px]"
    >
      <h4
        class="font-bold mb-4 font-body text-[20px] md:text-[25px] text-brand-text"
      >
        No side effects
      </h4>
      <p class="text-center md:text-left">
        The treatment consists of eliminating only the tobacco frequencies,
        without chemical substances or altering your organism. Therefore, it
        lacks contraindications.
      </p>
    </div>
    <div
      class="w-full md:w-1/4 p-6 md:p-10 text-brand-text text-[17px] leading-[37px]"
    >
      <h4
        class="font-bold mb-4 font-body text-[20px] md:text-[25px] text-brand-text"
      >
        Complete detoxification
      </h4>
      <p class="text-center md:text-left">
        It eliminates not only nicotine but also all chemical toxins from
        cigarettes, promoting a deep cleansing of the organism.
      </p>
    </div>
    <div
      class="w-full md:w-1/4 p-6 md:p-10 text-brand-text text-[17px] leading-[37px]"
    >
      <h4
        class="font-bold mb-4 font-body text-[20px] md:text-[25px] text-brand-text"
      >
        Improved wellbeing
      </h4>
      <p class="text-center md:text-left">
        Detoxifying the organism helps to experience greater energy, better
        breathing, and a recovery of your health.
      </p>
    </div>
  </section>

  <!-- Doctor Section -->
  <section class="bg-brand-secondary py-[50px]">
    <h2
      class="text-white font-heading font-bold text-[24px] md:text-[30px] uppercase text-center tracking-[0.9px]"
    >
      Doctor Enrique Fernández
    </h2>
  </section>
  <section
    class="bg-[radial-gradient(at_bottom_right,_var(--color-brand-primary)_0%,_var(--color-brand-secondary)_100%)] w-full py-[50px] px-4 text-white"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col md:flex-row">
      <div class="w-full md:w-1/3 flex justify-center mb-10 md:mb-0">
        <img
          src="/images/team/enrique.png"
          class="max-w-[421px] w-full object-contain"
          alt="Dr Enrique Fernandez photograph"
        />
      </div>
      <div
        class="w-full md:w-2/3 flex flex-col justify-center px-4 md:px-10 text-[17px] leading-[37px] text-center"
      >
        <p class="mb-6 font-body">
          Through my personal experience and after having helped very many
          people quit smoking for more than 41 years, I would say that quitting
          smoking comes down to a single decision:
        </p>

        <div
          class="bg-white text-brand-text rounded-[21px] p-8 mx-0 md:mx-[100px] mb-6 font-body"
        >
          <p class="mb-4">
            <strong><em>Do I want to quit smoking or not?</em></strong>
          </p>
          <p class="mb-4"><strong>Willpower is not necessary.</strong></p>
          <p>
            <strong
              >It is essential to <em>desire / want to quit smoking</em
              >.</strong
            >
          </p>
        </div>

        <p class="font-body mx-0 md:mx-10">
          There is a big difference between wanting to quit and having to quit
          smoking. Many people have to quit smoking due to medical prescription
          or because their family asks them to. However, if to <em
            >the obligation to quit smoking</em
          > you add the <em>desire to quit smoking</em>, the latter considerably
          boosts the treatment.
        </p>
      </div>
    </div>
  </section>

  <!-- Tratamiento de frecuencias (Dark blue bg with image) -->
  <section
    class="bg-brand-primary py-[100px] md:py-[200px] text-center bg-[url('/images/pages/frecuencias.png')] bg-center bg-contain bg-no-repeat w-full"
    id="Tratamiento"
  >
    <div class="max-w-[1200px] mx-auto px-4 flex flex-col items-center">
      <h2
        class="text-white font-heading font-bold text-[24px] md:text-[30px] uppercase mb-10 tracking-[0.9px]"
      >
        ADVANCED FREQUENCY TREATMENT
      </h2>
      <div
        class="text-white text-[20px] md:text-[24px] leading-[1.3em] font-body font-normal max-w-full md:max-w-[60%]"
      >
        <p class="mb-6">
          <i
            >Everything that EXISTS possesses and emits a unique frequency and
            wavelength, like a fingerprint.</i
          >
        </p>
        <p class="mb-6">
          Every FREQUENCY is vibrational <span class="underline"
            >information</span
          >.
        </p>
        <p>Every VIBRATION – INFORMATION is susceptible to being modified.</p>
      </div>
    </div>
  </section>

  <!-- Content & Canvas -->
  <section class="bg-brand-primary w-full pb-20">
    <div
      class="max-w-[1200px] mx-auto flex flex-col md:flex-row px-4 text-white"
    >
      <!-- Left text -->
      <div
        class="w-full md:w-1/2 text-[17px] leading-[37px] font-body font-normal pr-0 md:pr-10"
      >
        <h3
          class="text-brand-secondary font-heading font-bold text-[25px] mt-6 mb-4"
        >
          What should you know?
        </h3>
        <p class="mb-4">
          The treatment to quit smoking is simple. A single one-hour session is
          enough to break free from tobacco addiction, with no need for
          willpower. Only the genuine desire to quit is required.
        </p>
        <p class="mb-8">
          We use a treatment based on electromagnetic bio-frequencies, which
          allows the elimination of the information of nicotine and all
          substances present in tobacco (tars, cadmium, lead, arsenic, ammonia,
          benzenes, among others). By inverting these frequencies in the body,
          we manage to neutralize their effects.
        </p>

        <h3
          class="text-brand-secondary font-heading font-bold text-[25px] mt-6 mb-4"
        >
          Why does the withdrawal syndrome not occur?
        </h3>
        <p class="mb-4">
          When you smoke, tobacco smoke permeates every cell in your body,
          leaving a mark in the form of electromagnetic frequencies. Even if you
          quit smoking on your own, this information remains and continues to
          negatively affect your organism.
        </p>
        <p class="mb-8">
          Only through an electromagnetic elimination of these frequencies is it
          possible to completely cancel the information associated with tobacco,
          whether from cigarettes, cigars, pipe tobacco, or vapes. The result is
          an organism as if you had never smoked. While previous lesions caused
          by tobacco may still be present, your health status will noticeably
          improve and you will have the capacity to recover to the greatest
          extent possible.
        </p>

        <h3
          class="text-brand-secondary font-heading font-bold text-[25px] mt-6 mb-4"
        >
          Professional in charge
        </h3>
        <p>
          The treatment is performed by Ms. Miriam Matía, a psychologist
          specialized in Homeopathy, with a high qualification and experience in
          this type of therapy for over 20 years. If necessary, the treatment
          can be complemented with Homeopathic medicine.
        </p>
      </div>

      <!-- Right canvas diagram -->
      <div
        class="w-full md:w-1/2 mt-10 md:mt-0 hidden xl:flex items-start justify-center"
      >
        <!-- Mora Diagram HTML -->
        <div
          class="mora-diagram-container w-full max-w-[42rem] mx-auto bg-brand-primary p-10 rounded-[1rem] shadow-xl font-body border border-white/10 mt-6"
        >
          <h3 class="text-white text-2xl font-bold text-left mb-8">
            The bio-frequency-based treatment harmonizes your body and
            eliminates the tobacco information at the same time
          </h3>

          <div class="grid grid-cols-1 gap-4 md:gap-6">
            <!-- Señal Saludable -->
            <div>
              <h4 class="text-white text-lg font-semibold mb-2">
                Healthy Signal (Harmonic)
              </h4>
              <canvas
                id="harmonicWaveDiagram"
                class="rounded-lg w-full h-[120px] block shadow-inner bg-[#D1FAE5]"
              ></canvas>
            </div>
            <!-- Señal del tabaco -->
            <div>
              <h4 class="text-white text-lg font-semibold mb-2">
                Tobacco and other toxins Signal (Disharmonic)
              </h4>
              <canvas
                id="disharmonicWaveDiagram"
                class="rounded-lg w-full h-[120px] block shadow-inner bg-[#FEE2E2]"
              ></canvas>
            </div>
            <!-- Señal Invertida -->
            <div>
              <h4 class="text-white text-lg font-semibold mb-2">
                Inverted Signal (of tobacco)
              </h4>
              <canvas
                id="invertedTobaccoWaveDiagram"
                class="rounded-lg w-full h-[120px] block shadow-inner bg-[#FFFBEB]"
              ></canvas>
            </div>
            <!-- Salida Terapéutica -->
            <div>
              <h4 class="text-white text-lg font-semibold mb-2">
                Therapeutic Output (Cancellation and Amplification)
              </h4>
              <canvas
                id="therapeuticWaveDiagram"
                class="rounded-lg w-full h-[144px] block shadow-inner bg-[#DBEAFE]"
              ></canvas>
            </div>
          </div>

          <!-- Botones -->
          <button
            id="runTherapyBtnDiagram"
            class="text-white font-bold py-3 px-6 rounded-lg w-full border-none cursor-pointer transition-colors mt-6 bg-[#4C51BF] hover:bg-[#6D28D9] active:bg-[#4B088A] disabled:opacity-70 disabled:cursor-not-allowed"
          >
            Therapy Simulation
          </button>
          <button
            id="resetTherapyBtnDiagram"
            class="text-white font-bold py-3 px-6 rounded-lg w-full border-none cursor-pointer transition-colors mt-3 bg-[#6B7280] hover:bg-[#4B5563] active:bg-[#374151] disabled:opacity-70 disabled:cursor-not-allowed"
          >
            Reset Simulation
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Preguntas frecuentes -->
  <section class="max-w-[1200px] mx-auto px-4 py-[50px]">
    <h2
      class="text-brand-primary font-heading font-bold text-[30px] uppercase mb-10 tracking-[0.9px]"
    >
      frequently asked questions
    </h2>

    <div
      class="space-y-10 text-brand-text text-[17px] leading-[37px] font-body"
    >
      <div>
        <h3
          class="text-brand-secondary font-heading font-bold text-[25px] mb-4"
        >
          What should I do after the treatment?
        </h3>
        <p>
          It is important to drink plenty of water during the following days
          after the treatment so your body releases accumulated toxins more
          easily. In the years I have been doing the anti-tobacco treatment, I
          have never modified the patients' habits. They can continue drinking
          coffee, going out at night, or any other activity they did when they
          smoked. At approximately 4-7 days of the treatment, the habits fade
          and even most patients don't even remember tobacco.
        </p>
      </div>
      <div>
        <h3
          class="text-brand-secondary font-heading font-bold text-[25px] mb-4"
        >
          How is anxiety managed? Do you gain weight afterward?
        </h3>
        <p class="mb-4">
          Do you have Anxiety? And does tobacco calm you down? What will happen
          when you quit smoking?<br />If there is a <em>baseline anxiety</em> that
          is calmed with tobacco, when removing the habit of smoking one might continue
          with that anxiety and the tendency might be to substitute tobacco for food.
          Homeopathic Medicine helps a lot in these cases, so the fear of gaining
          weight situation should not prevent you from taking your anti-tobacco treatment.
        </p>
        <p>
          Gaining weight? Many people are concerned about gaining weight upon
          quitting smoking. There is no physiological correlation between
          quitting smoking and gaining weight.
        </p>
      </div>
      <div>
        <h3
          class="text-brand-secondary font-heading font-bold text-[25px] mb-4"
        >
          And the remaining 5%?
        </h3>
        <p>
          We find that in 5% of cases people come obliged by their relatives or
          without knowing if they truly want to quit smoking. Given that the
          treatment works, it is important that you come to the consultation <strong
            ><em>wanting</em></strong
          > to quit smoking. By eliminating physical and psychological dependence,
          it will be easy for you to stay without smoking since your body will not
          ask you to smoke.
        </p>
      </div>
    </div>
  </section>

  <Locations />

  <ContactSection />
</Layout>

<script>
  // Mora Diagram Animation Script
  document.addEventListener("DOMContentLoaded", function () {
    const harmonicCanvasDiagram = document.getElementById(
      "harmonicWaveDiagram",
    ) as HTMLCanvasElement;
    const disharmonicCanvasDiagram = document.getElementById(
      "disharmonicWaveDiagram",
    ) as HTMLCanvasElement;
    const invertedTobaccoCanvasDiagram = document.getElementById(
      "invertedTobaccoWaveDiagram",
    ) as HTMLCanvasElement;
    const therapeuticCanvasDiagram = document.getElementById(
      "therapeuticWaveDiagram",
    ) as HTMLCanvasElement;
    const runTherapyBtnDiagram = document.getElementById(
      "runTherapyBtnDiagram",
    ) as HTMLButtonElement;
    const resetTherapyBtnDiagram = document.getElementById(
      "resetTherapyBtnDiagram",
    ) as HTMLButtonElement;

    if (
      !harmonicCanvasDiagram ||
      !disharmonicCanvasDiagram ||
      !invertedTobaccoCanvasDiagram ||
      !therapeuticCanvasDiagram ||
      !runTherapyBtnDiagram ||
      !resetTherapyBtnDiagram
    ) {
      return;
    }

    let animationFrameIdDiagram: number;
    let therapyIntervalId: ReturnType<typeof setInterval>;
    let phaseDiagram = 0;

    function resizeCanvas(canvas: HTMLCanvasElement) {
      if (canvas) {
        canvas.width = canvas.offsetWidth;
        canvas.height = canvas.offsetHeight;
      }
    }

    const canvasesToResize = [
      harmonicCanvasDiagram,
      disharmonicCanvasDiagram,
      invertedTobaccoCanvasDiagram,
      therapeuticCanvasDiagram,
    ];
    canvasesToResize.forEach((canvas) => resizeCanvas(canvas));

    window.addEventListener("resize", () => {
      canvasesToResize.forEach((canvas) => resizeCanvas(canvas));
      drawWaveDiagram(harmonicCanvasDiagram, "#10B981", 2, 40, phaseDiagram);
      drawWaveDiagram(
        disharmonicCanvasDiagram,
        "#EF4444",
        2,
        40,
        phaseDiagram,
        true,
      );

      if (runTherapyBtnDiagram.textContent === "Therapy Completed!") {
        drawInvertedTobaccoWave(
          invertedTobaccoCanvasDiagram,
          "#FDBA74",
          2,
          40,
          phaseDiagram,
          100,
        );
        drawTherapeuticWave(100);
      } else {
        drawInvertedTobaccoWave(
          invertedTobaccoCanvasDiagram,
          "#FDBA74",
          2,
          40,
          phaseDiagram,
          0,
        );
        drawTherapeuticWave(0);
      }
    });

    function drawWaveDiagram(
      canvas: HTMLCanvasElement,
      color: string,
      frequency: number,
      amplitude: number,
      phase: number,
      isDisharmonic = false,
    ) {
      const ctx = canvas.getContext("2d");
      if (!ctx) return;
      const width = canvas.width;
      const height = canvas.height;
      ctx.clearRect(0, 0, width, height);
      ctx.beginPath();
      ctx.lineWidth = 3;
      ctx.strokeStyle = color;

      for (let x = 0; x < width; x++) {
        const angle = (x / width) * 2 * Math.PI * frequency + phase;
        let y = height / 2 + Math.sin(angle) * amplitude;

        if (isDisharmonic) {
          y += Math.sin(angle * 5) * amplitude * 0.3;
          y += Math.cos(angle * 2.5) * amplitude * 0.2;
        }
        if (x === 0) {
          ctx.moveTo(x, y);
        } else {
          ctx.lineTo(x, y);
        }
      }
      ctx.stroke();
    }

    function drawInvertedTobaccoWave(
      canvas: HTMLCanvasElement,
      color: string,
      frequency: number,
      amplitude: number,
      phase: number,
      progress: number,
    ) {
      const ctx = canvas.getContext("2d");
      if (!ctx) return;
      const width = canvas.width;
      const height = canvas.height;
      ctx.clearRect(0, 0, width, height);
      ctx.beginPath();
      ctx.lineWidth = 3;
      ctx.strokeStyle = color;

      const currentAmplitude = amplitude * (1 - progress / 100);

      if (currentAmplitude <= 0) {
        ctx.moveTo(0, height / 2);
        ctx.lineTo(width, height / 2);
        ctx.stroke();
        return;
      }

      for (let x = 0; x < width; x++) {
        const angle = (x / width) * 2 * Math.PI * frequency + phase;
        let y_raw = Math.sin(angle) * currentAmplitude;
        y_raw += Math.sin(angle * 5) * currentAmplitude * 0.3;
        y_raw += Math.cos(angle * 2.5) * currentAmplitude * 0.2;

        const y = height / 2 - y_raw;

        if (x === 0) {
          ctx.moveTo(x, y);
        } else {
          ctx.lineTo(x, y);
        }
      }
      ctx.stroke();
    }

    function drawTherapeuticWave(progress: number) {
      const ctx = therapeuticCanvasDiagram.getContext("2d");
      if (!ctx) return;
      const width = therapeuticCanvasDiagram.width;
      const height = therapeuticCanvasDiagram.height;
      ctx.clearRect(0, 0, width, height);
      ctx.beginPath();
      ctx.lineWidth = 3;
      ctx.strokeStyle = "#3B82F6";

      const baseAmplitude = 40;
      const finalHealedAmplitude = baseAmplitude * 1.5;
      const maxAllowedDeviation = (height / 2) * 0.9;

      for (let x = 0; x < width; x++) {
        const harmonicAngle = (x / width) * 2 * Math.PI * 2 + phaseDiagram;
        const disharmonicAngle = (x / width) * 2 * Math.PI * 2 + phaseDiagram;

        const harmonicYComponent = Math.sin(harmonicAngle) * baseAmplitude;

        let disharmonicYComponentRaw =
          Math.sin(disharmonicAngle) * baseAmplitude;
        disharmonicYComponentRaw +=
          Math.sin(disharmonicAngle * 5) * baseAmplitude * 0.3;
        disharmonicYComponentRaw +=
          Math.cos(disharmonicAngle * 2.5) * baseAmplitude * 0.2;

        const theoreticalMaxInitialDeviation = baseAmplitude * 2.5;
        const initialScaledDeviationFactor =
          maxAllowedDeviation / theoreticalMaxInitialDeviation;
        const initialYValue =
          height / 2 +
          (harmonicYComponent - disharmonicYComponentRaw) *
            initialScaledDeviationFactor;
        const finalYValue =
          height / 2 + Math.sin(harmonicAngle) * finalHealedAmplitude;

        const t = progress / 100;
        let y = initialYValue * (1 - t) + finalYValue * t;

        y = Math.max(0, Math.min(height, y));

        if (x === 0) {
          ctx.moveTo(x, y);
        } else {
          ctx.lineTo(x, y);
        }
      }
      ctx.stroke();
    }

    function animateWavesDiagram() {
      phaseDiagram += 0.05;

      drawWaveDiagram(harmonicCanvasDiagram, "#10B981", 2, 40, phaseDiagram);
      drawWaveDiagram(
        disharmonicCanvasDiagram,
        "#EF4444",
        2,
        40,
        phaseDiagram,
        true,
      );

      if (
        !runTherapyBtnDiagram.disabled ||
        runTherapyBtnDiagram.textContent === "Therapy Completed!"
      ) {
        if (runTherapyBtnDiagram.textContent !== "Therapy Completed!") {
          drawInvertedTobaccoWave(
            invertedTobaccoCanvasDiagram,
            "#FDBA74",
            2,
            40,
            phaseDiagram,
            0,
          );
          drawTherapeuticWave(0);
        } else {
          drawInvertedTobaccoWave(
            invertedTobaccoCanvasDiagram,
            "#FDBA74",
            2,
            40,
            phaseDiagram,
            100,
          );
          drawTherapeuticWave(100);
        }
      }

      animationFrameIdDiagram = requestAnimationFrame(animateWavesDiagram);
    }

    function resetDiagram() {
      clearInterval(therapyIntervalId);
      runTherapyBtnDiagram.disabled = false;
      runTherapyBtnDiagram.textContent = "Therapy Simulation";
      runTherapyBtnDiagram.style.backgroundColor = "#4C51BF";

      phaseDiagram = 0;

      canvasesToResize.forEach((canvas) => resizeCanvas(canvas));
      drawWaveDiagram(harmonicCanvasDiagram, "#10B981", 2, 40, phaseDiagram);
      drawWaveDiagram(
        disharmonicCanvasDiagram,
        "#EF4444",
        2,
        40,
        phaseDiagram,
        true,
      );
      drawInvertedTobaccoWave(
        invertedTobaccoCanvasDiagram,
        "#FDBA74",
        2,
        40,
        phaseDiagram,
        0,
      );
      drawTherapeuticWave(0);
    }

    runTherapyBtnDiagram.addEventListener("click", () => {
      if (runTherapyBtnDiagram.disabled) {
        return;
      }

      runTherapyBtnDiagram.disabled = true;
      runTherapyBtnDiagram.textContent = "Therapy in Progress...";
      runTherapyBtnDiagram.style.backgroundColor = "#6D28D9";

      let progress = 0;

      if (therapyIntervalId) {
        clearInterval(therapyIntervalId);
      }

      therapyIntervalId = setInterval(() => {
        progress += 1;
        drawInvertedTobaccoWave(
          invertedTobaccoCanvasDiagram,
          "#FDBA74",
          2,
          40,
          phaseDiagram,
          progress,
        );
        drawTherapeuticWave(progress);

        if (progress >= 100) {
          clearInterval(therapyIntervalId);
          runTherapyBtnDiagram.textContent = "Therapy Completed!";
          runTherapyBtnDiagram.style.backgroundColor = "#16A34A";
        }
      }, 20);
    });

    resetTherapyBtnDiagram.addEventListener("click", resetDiagram);

    animateWavesDiagram();
  });
</script>
