  <!-- LA TECNOLOGIA MORA® NOVA -->
  <section class="max-w-[1200px] mx-auto px-4 pb-16">
    <h2
      class="font-heading font-bold text-[30px] text-brand-primary uppercase tracking-[0.9px] mb-6 text-center"
    >
      MORA® NOVA TECHNOLOGY
    </h2>
    <p class="font-body text-[17px] leading-[37px] text-brand-text mb-8">
      In the context of MORA bio-resonance, wave cancellation illustrates how,
      by identifying the disharmonious electromagnetic frequencies of a body
      (those associated with an imbalance or disease) and generating an exactly
      opposite signal, these "negative" frequencies can be cancelled. This
      cancellation process seeks to "erase" pathological information and restore
      the body's natural energetic balance, thus facilitating its own
      self-healing mechanisms and allowing therapies to be more effective.
    </p>

    <!-- Wave Animation Canvas -->
    <div class="animation-container shadow-lg">
      <canvas id="frequencyCanvas"></canvas>
    </div>

    <style>
      .animation-container {
        width: 100%;
        max-width: 1200px;
        margin: auto;
        position: relative;
        background-color: #ffffff;
        border-radius: 8px;
        overflow: hidden;
        box-sizing: border-box;
        aspect-ratio: 16 / 5;
        font-family: "Open Sans", sans-serif;
      }
      canvas {
        display: block;
        width: 100%;
        height: 100%;
        background-color: #ffffff;
      }
      @media (max-width: 768px) {
        .animation-container {
          aspect-ratio: 16 / 9;
          border-radius: 4px;
        }
