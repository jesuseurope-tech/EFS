---
import Layout from "../../../layouts/Layout.astro";
import ContactSection from "../../../components/ContactSection.astro";
import { getLangFromUrl } from "../../../i18n/utils";
import Locations from "../../../components/Locations.astro";

const lang = getLangFromUrl(Astro.url);
---

<Layout title="Medical Treatments" lang={lang}>
  <!-- Main Content -->
  <section
    class="max-w-[1200px] w-full mx-auto px-4 py-[50px] md:py-[100px] pt-[150px]"
  >
    <!-- Hero Section -->
    <div class="flex flex-col md:flex-row gap-8 items-center mb-16">
      <div class="md:w-1/2">
        <h2
          class="font-heading font-bold text-[30px] text-brand-primary uppercase tracking-[0.9px] mb-6"
        >
          Medical Solutions for your Health
        </h2>
        <div
          class="font-body text-brand-text text-[17px] leading-[37px] space-y-4"
        >
          <p>
            With over 40 years of experience in General Medicine and Homeopathy,
            my goal is to go beyond the symptom. Using advanced diagnosis with
            bio-frequencies, we do not limit ourselves to putting a label on
            your illness; instead, we look for its <strong>root cause</strong> to
            restore your body's natural balance.
          </p>
          <p>
            We treat the <strong>"Human Being"</strong> as a whole, understanding
            that the place where a problem appears is rarely its true origin. Below,
            I present the treatment areas I address in my practice, from our main
            solutions to addressing a wide range of conditions.
          </p>
        </div>
      </div>
      <div class="md:w-1/2 flex justify-center">
        <img
          src="/images/treatments/white-background-mobile.png"
          class="max-h-[500px] object-contain"
          alt="Medical Treatments"
