---
import Layout from "../layouts/Layout.astro";
import ContactSection from "../components/ContactSection.astro";
import WaveDivider from "../components/WaveDivider.astro";
import Locations from "../components/Locations.astro";
import QuoteSlider from "../components/QuoteSlider.astro";
import MainTreatments from "../components/MainTreatments.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

import HeroSection from "../components/HeroSection.astro";
import ProcessIcon from "../components/ProcessIcon.astro";
import DoctorProfileCard from "../components/DoctorProfileCard.astro";

const lang = getLangFromUrl(Astro.url);
// Here we will use hardcoded Spanish for `index.astro` since the prompt said build Spanish Home Page `src/pages/index.astro`.
// For English, we will build `src/pages/en/index.astro` or use strings.
---

<Layout title="Consulta Médica" lang="es">
  <!-- Hero Section -->
  <HeroSection lang={lang} />

  <!-- Nuestra consulta Section -->
  <section class="py-[50px] max-w-[1200px] mx-auto px-4">
    <h2
      class="text-[30px] font-heading font-bold uppercase text-brand-primary mb-[40px] text-left md:text-center"
    >
      Nuestra consulta
    </h2>

    <div class="flex flex-col gap-[50px]">
      <!-- Step 1 -->
      <div class="flex flex-col items-center text-center max-w-[800px] mx-auto">
        <div class="w-full flex justify-center mb-6">
          <a
            class="inline-block hover:scale-105 transition-transform"
            href="/diagnostico-medico/"
          >
            <ProcessIcon step={1} />
          </a>
        </div>
        <div>
          <h4 class="font-body text-[25px] font-normal mb-4">
            1. Evaluación Médica Inicial en Profundidad
          </h4>
          <p class="text-brand-text leading-[37px]">
            Frente a un modelo médico a menudo limitado por el tiempo, para
            comprender la etiología de su condición, es imprescindible conocer
            bien al paciente. Por ello, dedicamos el tiempo que sea necesario
            para profundizar no solo en su biografía médica, sino también en su <strong
              >historia familiar, su entorno vital y su contexto</strong
            >. Entender dónde vive, cómo se relaciona y qué desafíos ha
            enfrentado nos proporciona claves diagnósticas cruciales que a
            menudo se pasan por alto.
          </p>
        </div>
      </div>

      <!-- Step 2 -->
      <div
        class="flex flex-col items-center text-center max-w-[800px] mx-auto p-4 rounded-[15px] hover:shadow-lg transition duration-300"
      >
        <div class="w-full flex justify-center mb-6">
          <a
            class="inline-block hover:scale-105 transition-transform"
            href="/diagnostico-medico/"
          >
            <ProcessIcon step={2} />
          </a>
        </div>
        <div>
          <h4 class="font-body text-[25px] font-normal mb-4">
            2. Diagnóstico Médico de Precisión
          </h4>
          <p class="text-brand-text leading-[37px] mb-4">
            Tras el análisis clínico inicial, aplicamos tecnología de vanguardia
            para obtener una evaluación funcional completa. Nuestro Diagnóstico
            Médico mediante <strong>Bio-resonancia MORA ®</strong> permite un análisis
            objetivo de la actividad celular y sistémica, identificando desequilibrios,
            cargas tóxicas, intolerancias o focos interferentes que no siempre son
            detectables por métodos convencionales. Este paso es crucial para determinar
            con precisión la etiología (causa raíz) de su patología.
          </p>
          <a href="/diagnostico-medico/" class="capitalize"
            >Conozca nuestra metodología diagnóstica</a
          >
        </div>
      </div>

      <!-- Step 3 -->
      <div class="flex flex-col items-center text-center max-w-[800px] mx-auto">
        <div class="w-full flex justify-center mb-6">
          <a
            class="inline-block hover:scale-105 transition-transform"
            href="/tratamientos/"
          >
            <ProcessIcon step={3} />
          </a>
        </div>
        <div>
          <h4 class="font-body text-[25px] font-normal mb-4">
            3. Estrategia Terapéutica Personalizada
          </h4>
          <p class="text-brand-text leading-[37px] mb-4">
            Basándonos en la evidencia clínica y funcional obtenida, diseñamos
            una <strong
              >estrategia terapéutica rigurosa y específica para cada paciente</strong
            >. No ofrecemos soluciones genéricas, sino planes de tratamiento
            individualizados que pueden integrar diferentes modalidades, como la <strong
              >Homeopatía clínica</strong
            >, protocolos de <strong>Desintoxicación avanzada</strong> o nuestro eficaz
            <strong>Tratamiento Antitabaco</strong>, con el fin de restaurar la
            homeostasis y promover una recuperación estable y duradera.
          </p>
          <a href="/tratamientos/" class="capitalize"
            >Explore nuestras áreas de tratamiento</a
          >
        </div>
      </div>
    </div>
  </section>

  <!-- Principales Tratamientos Menu Block -->
  <MainTreatments />

  <!-- ACERCA DE NOSOTROS section -->
  <section class="bg-brand-secondary py-[50px]">
    <div class="max-w-[1200px] w-full mx-auto px-4">
      <h2
        class="text-[30px] font-heading font-bold uppercase text-white mb-[20px]"
      >
        ACERCA DE NOSOTROS
      </h2>
      <p class="text-white text-[16px]">
        Consulta especializada en encontrar la causa de la enfermedad, dando
        solución a problemas, enfermedades y bloqueos.
      </p>
    </div>
  </section>

  <!-- Slider and Floating Content Section -->
  <section
    class="relative bg-gradient-to-br from-[#126892] to-brand-secondary pb-[100px]"
  >
    <!-- Background shape divider -->
    <div class="absolute top-0 left-0 w-full overflow-hidden leading-[0]">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1000 100"
        preserveAspectRatio="none"
        class="w-[calc(100%+1.3px)] h-[100px] block"
        style="transform: rotateX(180deg);"
      >
        <path class="fill-white" d="M0,6V0h1000v100L0,6z"></path>
      </svg>
    </div>

    <div
      class="max-w-[1200px] w-full mx-auto px-4 pt-[60px] relative z-10 flex flex-col items-center"
    >
      <!-- Info Box (El ser humano es un TODO) -->
      <div
        class="w-full max-w-[800px] p-[40px] bg-white bg-opacity-95 hover:bg-opacity-100 transition-all duration-300 shadow-xl mb-12"
      >
        <div class="text-center font-bold text-[#333333] mb-4">
          El ser humano es un TODO.
        </div>
        <div class="text-left text-[#333333] mb-4">
          No se puede separar su parte física de su sistema emocional, mental e
          incluso espiritual.
        </div>
        <div class="text-center text-[#333333] mb-4 italic">
          «No hay enfermedad física sin un síntoma mental o emocional que se
          correlacione»
        </div>
        <div class="text-center text-[#333333] mb-4">ni al contrario</div>
        <div class="text-center text-[#333333] mb-4 italic">
          «un síntoma mental, emocional sin que haya un síntoma físico».
        </div>
        <div class="text-left text-[#333333] mb-4">
          Esta sincronización es importante investigarla, tratarla para
          recuperar la salud y la armonía a todos los niveles.
        </div>
        <div class="text-center text-[#333333]">¿Por qué me enfermo?</div>
        <div class="text-center text-[#333333]">
          ¿Por qué me pasa lo que tengo?
        </div>
        <div class="text-center text-[#333333]">
          ¿Por qué se mantienen los síntomas a través del tiempo?
        </div>
        <div class="text-center text-[#333333] mb-4">
          ¿Qué significa esta enfermedad?
        </div>
        <div class="text-center text-[#333333] font-bold mb-4">
          Todo tiene relación puesto que TODO está en UNO.
        </div>
        <div class="text-center text-[#333333]">
          Ayudarle a desvelar esto, es mi trabajo y especialidad.
        </div>
      </div>

      <!-- Tabs Controls -->
      <div class="w-full max-w-[1000px]">
        <div
          class="flex flex-col sm:flex-row w-full mb-8 rounded-t-md overflow-hidden bg-white/10"
        >
          <button
            class="tab-bio-btn flex-1 px-6 py-4 bg-[#1B9EDB] text-white text-[15px] font-bold font-heading uppercase tracking-wide hover:bg-[#126892] hover:text-white transition-colors border-r border-white/20 last:border-r-0"
            data-tab="consulta">Consulta</button
          >
          <button
            class="tab-bio-btn flex-1 px-6 py-4 bg-transparent text-white text-[15px] font-bold font-heading uppercase tracking-wide hover:bg-[#126892] hover:text-white transition-colors border-r border-white/20 last:border-r-0"
            data-tab="enrique">Doctor Enrique Fernández</button
          >
          <button
            class="tab-bio-btn flex-1 px-6 py-4 bg-transparent text-white text-[15px] font-bold font-heading uppercase tracking-wide hover:bg-[#126892] hover:text-white transition-colors border-r border-white/20 last:border-r-0"
            data-tab="miriam">Psicologa Miriam Matia</button
          >
        </div>

        <div
          id="tab-bio-consulta"
          class="tab-bio-content active bg-transparent text-white"
        >
          <h3 class="text-center text-[22px] font-bold mb-2">
            Atención Personalizada
          </h3>
          <p class="text-center leading-[37px] mb-8">
            Dedicando el tiempo necesario para comprender a fondo su situación,
            con una Historia Clínica completa.
          </p>

          <h3 class="text-center text-[22px] font-bold mb-2">
            Diagnóstico Completo
          </h3>
          <p class="text-center leading-[37px] mb-8">
            Realizo un diagnóstico global sistémico (de todo el cuerpo)
            investigando las causas profundas de su enfermedad o dolencia.
          </p>

          <h3 class="text-center text-[22px] font-bold mb-2">
            Especialidades <br />Médicas
          </h3>
          <p class="text-center leading-[37px]">
            Utilizo los avances en Medicina Electromagnética junto con la
            experiencia de mas de 40 años en el ejercicio de la Medicina
            Homeopática.
          </p>
        </div>

        <div
          id="tab-bio-enrique"
          class="tab-bio-content hidden bg-transparent text-white"
        >
          <DoctorProfileCard
            name="Doctor Enrique Fernández"
            role="Licenciado en Medicina y Cirugía por la Universidad del País Vasco (España) y, desde 1984, me dedico a la práctica de la Medicina en mi consulta."
            imageUrl="/images/team/enrique.png"
            linkUrl="/doctores/dr-enrique-fernandez"
          />
        </div>

        <div
          id="tab-bio-miriam"
          class="tab-bio-content hidden bg-transparent text-white"
        >
          <DoctorProfileCard
            name="Psicóloga Miriam Matia"
            role="Licenciada en psicología por La Universidad de Deusto, Bilbao y me dedico a la practica de la psicología, la homeopatía y los tratamientos de desintoxicación, antitabaco y adicciones en nuestra consulta."
            imageUrl="/images/team/Miriam.png"
            linkUrl="/doctores/dra-miriam-matia"
          />
        </div>
      </div>
    </div>
  </section>

  <QuoteSlider />
  <Locations />
  <ContactSection />
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const tabBtns = document.querySelectorAll(".tab-bio-btn");
    const tabContents = document.querySelectorAll(".tab-bio-content");

    tabBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const targetId = btn.getAttribute("data-tab");

        // Remove active classes
        tabBtns.forEach((b) => {
          b.classList.remove("bg-[#1B9EDB]", "text-white");
          b.classList.add("bg-transparent", "text-white");
        });
        tabContents.forEach((content) => {
          content.classList.add("hidden");
          content.classList.remove("active");
        });

        // Add active classes to selected
        btn.classList.add("bg-[#1B9EDB]", "text-white");
        btn.classList.remove("bg-transparent");

        const targetContent = document.getElementById("tab-bio-" + targetId);
        if (targetContent) {
          targetContent.classList.remove("hidden");
          targetContent.classList.add("active");
        }
      });
    });
  });
</script>

<style>
  .hero-img {
    opacity: 0;
    animation: heroFadeIn 2s ease-in-out forwards;
  }
  @keyframes heroFadeIn {
    0% {
      opacity: 0;
    }
    100% {
      opacity: var(--final-opacity, 1);
    }
  }
</style>
